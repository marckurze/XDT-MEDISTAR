<Window x:Class="XdtDeviceBridge.App.FloatingInterfaceProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geräteanbindung"
        Width="410"
        Height="430"
        MinWidth="360"
        MinHeight="260"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="FloatingSymbolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI Symbol"/>
            <Setter Property="Foreground" Value="#14532D"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1A22C55E"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#6634D399"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#3322C55E"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#16A34A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FloatingSymbolToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI Symbol"/>
            <Setter Property="Foreground" Value="#14532D"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1A22C55E"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#6634D399"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#3322C55E"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#16A34A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#2A22C55E"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#16A34A"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#22C55E"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="8">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F6FFF9" Offset="0"/>
                <GradientStop Color="#E9F8EF" Offset="0.58"/>
                <GradientStop Color="#F8FFFB" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <StackPanel DockPanel.Dock="Left"
                                MaxWidth="210">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding InterfaceProfileName}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#18392A"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding InterfaceProfileName}"/>
                        <TextBlock Text="{Binding AisName, StringFormat=AIS: {0}}"
                                   Foreground="#46685A"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="🗗"
                                Style="{StaticResource FloatingSymbolButtonStyle}"
                                Margin="4,0,0,4"
                                Click="DockButton_Click"
                                ToolTip="Wieder andocken"
                                AutomationProperties.Name="Wieder andocken"/>
                        <Button Content="↺"
                                Style="{StaticResource FloatingSymbolButtonStyle}"
                                Margin="4,0,0,4"
                                Click="ResetButton_Click"
                                ToolTip="Vorgang zurücksetzen"
                                AutomationProperties.Name="Vorgang zurücksetzen"/>
                        <ToggleButton x:Name="PositionMemoryToggleButton"
                                      Content="📌"
                                      Style="{StaticResource FloatingSymbolToggleButtonStyle}"
                                      Margin="4,0,0,4"
                                      ToolTip="Position merken"
                                      AutomationProperties.Name="Position merken"
                                      Checked="PositionMemoryToggleButton_Changed"
                                      Unchecked="PositionMemoryToggleButton_Changed"/>
                        <ToggleButton x:Name="PinToggleButton"
                                      Content="🔝"
                                      Style="{StaticResource FloatingSymbolToggleButtonStyle}"
                                      Margin="4,0,0,4"
                                      ToolTip="Immer im Vordergrund"
                                      AutomationProperties.Name="Immer im Vordergrund"
                                      Checked="PinToggleButton_Changed"
                                      Unchecked="PinToggleButton_Changed"/>
                    </StackPanel>
                </DockPanel>

                <Border CornerRadius="8"
                        BorderThickness="0"
                        Background="#0AF6FFF9"
                        Padding="4"
                        Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Height="168">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.72*"/>
                            <ColumnDefinition Width="1.82*"/>
                            <ColumnDefinition Width="62"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0">
                            <TextBlock Text="{Binding DeviceType}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#102A1F"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding InterfaceProfileName}"
                                       FontSize="16"
                                       Foreground="#102A1F"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Grid Grid.Column="1"
                              Margin="-14,-10,-6,-4">
                            <Border Background="#10FFFFFF"
                                    CornerRadius="8"/>
                            <Image Source="{Binding DeviceImagePath}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDeviceImage}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="Kein Gerätebild"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDeviceImage}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Grid x:Name="FloatingPilotStatusOrbSurface"
                              Grid.Column="2"
                              Width="58"
                              Height="58"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Loaded="FloatingPilotStatusOrb_Loaded"
                              Unloaded="FloatingPilotStatusOrb_Unloaded"
                              DataContextChanged="FloatingPilotStatusOrb_DataContextChanged"
                              ToolTip="{Binding CurrentStatus}">
                            <Ellipse Width="46"
                                     Height="46"
                                     Tag="StatusOrb"
                                     RenderTransformOrigin="0.5,0.5"
                                     Opacity="0.92">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="18"
                                                      ShadowDepth="2"
                                                      Direction="270"
                                                      Color="#991B1B"
                                                      Opacity="0.34"/>
                                </Ellipse.Effect>
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.34,0.28"
                                                         GradientOrigin="0.22,0.18"
                                                         RadiusX="0.72"
                                                         RadiusY="0.72">
                                        <GradientStop Color="#FEE2E2" Offset="0"/>
                                        <GradientStop Color="#EF4444" Offset="0.42"/>
                                        <GradientStop Color="#B91C1C" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="46"
                                     Height="46"
                                     Tag="StatusOrbFlash"
                                     Opacity="0">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.34,0.28"
                                                         GradientOrigin="0.2,0.16"
                                                         RadiusX="0.75"
                                                         RadiusY="0.75">
                                        <GradientStop Color="#DCFCE7" Offset="0"/>
                                        <GradientStop Color="#22C55E" Offset="0.5"/>
                                        <GradientStop Color="#15803D" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="14"
                                     Height="10"
                                     Fill="#CCFFFFFF"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     Margin="15,12,0,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border CornerRadius="6"
                        BorderThickness="1"
                        BorderBrush="#14532D"
                        Background="#082116"
                        Padding="6"
                        Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid x:Name="FloatingMonitoringRadarSurface"
                          Height="54"
                          ClipToBounds="True"
                          Loaded="FloatingMonitoringRadar_Loaded"
                          Unloaded="FloatingMonitoringRadar_Unloaded"
                          DataContextChanged="FloatingMonitoringRadar_DataContextChanged"
                          SizeChanged="FloatingMonitoringRadar_SizeChanged">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#08291D" Offset="0"/>
                                <GradientStop Color="#0F3A2A" Offset="0.55"/>
                                <GradientStop Color="#05130E" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#1F6B46" BorderThickness="0,0,0,1" Opacity="0.55"/>
                            <Border Grid.Row="1" BorderBrush="#1F6B46" BorderThickness="0,0,0,1" Opacity="0.45"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#1F6B46" BorderThickness="0,0,1,0" Opacity="0.35"/>
                            <Border Grid.Column="1" BorderBrush="#1F6B46" BorderThickness="0,0,1,0" Opacity="0.45"/>
                            <Border Grid.Column="2" BorderBrush="#1F6B46" BorderThickness="0,0,1,0" Opacity="0.35"/>
                        </Grid>
                        <Rectangle x:Name="FloatingRadarScanBar"
                                   Height="46"
                                   Width="17"
                                   RadiusX="3"
                                   RadiusY="3"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Opacity="0.58">
                            <Rectangle.RenderTransform>
                                <TranslateTransform/>
                            </Rectangle.RenderTransform>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#002417" Offset="0"/>
                                    <GradientStop Color="#10B981" Offset="0.38"/>
                                    <GradientStop Color="#BBF7D0" Offset="0.52"/>
                                    <GradientStop Color="#10B981" Offset="0.66"/>
                                    <GradientStop Color="#002417" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Border BorderBrush="#5EEA92"
                                BorderThickness="1"
                                Opacity="0.32"/>
                        <TextBlock Text="{Binding CurrentStatus}"
                                   Foreground="#BBF7D0"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Bottom"
                                   Margin="6,0,0,4"/>
                        <TextBlock Text="{Binding ScanIntervalText, StringFormat=Scan {0}}"
                                   Foreground="#BBF7D0"
                                   FontSize="10"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,6,4"/>
                    </Grid>
                </Border>

                <WrapPanel Margin="0,0,0,8">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <Button Content="−"
                            Style="{StaticResource FloatingSymbolButtonStyle}"
                            Margin="0,0,4,4"
                            Click="DecreaseScanIntervalButton_Click"
                            ToolTip="Scanintervall um 1 Sekunde verringern"/>
                    <TextBlock Text="{Binding ScanIntervalText, StringFormat=Intervall: {0}}"
                               VerticalAlignment="Center"
                               Margin="0,2,4,4"/>
                    <Button Content="+"
                            Style="{StaticResource FloatingSymbolButtonStyle}"
                            Margin="0,0,12,4"
                            Click="IncreaseScanIntervalButton_Click"
                            ToolTip="Scanintervall um 1 Sekunde erhöhen"/>
                    <TextBlock Text="{Binding LastScanText, StringFormat=Letzter Scan: {0}}"
                               Margin="0,0,12,4"/>
                    <TextBlock Text="{Binding AutomaticProcessingText, StringFormat=Automatik: {0}}"
                               Margin="0,0,0,4"/>
                </WrapPanel>

                <WrapPanel Margin="0,0,0,8"
                           HorizontalAlignment="Left">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <Button Content="−"
                            Style="{StaticResource FloatingSymbolButtonStyle}"
                            Margin="0,0,8,4"
                            Click="DecreaseScanIntervalButton_Click"
                            ToolTip="Scanintervall um 1 Sekunde verringern"/>
                    <TextBlock Text="{Binding ScanIntervalText, StringFormat=Intervall: {0}}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,2,8,4"/>
                    <Button Content="+"
                            Style="{StaticResource FloatingSymbolButtonStyle}"
                            Margin="0,0,0,4"
                            Click="IncreaseScanIntervalButton_Click"
                            ToolTip="Scanintervall um 1 Sekunde erhöhen"/>
                </WrapPanel>

                <TextBlock Text="Erwartete Eingänge"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding ExpectedInputs}"
                              Margin="0,0,0,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#D6CDB9"
                                    Background="#FFFDF7"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6"
                                    Width="106"
                                    Margin="0,0,4,6"
                                    ToolTip="{Binding Detail}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Status}" Foreground="DimGray" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DisplayDetail}"
                                               Foreground="#4B5563"
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               MaxHeight="34"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Expander Header="Details" IsExpanded="{Binding IsDetailsExpanded, Mode=OneWay}">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock Text="{Binding DeviceName, StringFormat=Gerät: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ExportProfileName, StringFormat=Exportprofil: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding LastScanText, StringFormat=Letzter Scan: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding AutomaticProcessingText, StringFormat=Automatik: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding AttachmentConfigurationStatus, StringFormat=Anhang: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding LastMessage, StringFormat=Letzte Meldung: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding PatientDisplayText, StringFormat=Patient: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding LastSuccessfulExportText, StringFormat=Letzter Erfolg: {0}}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
