<Window x:Class="XdtDeviceBridge.App.AppSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XDTBox Einstellungen"
        Icon="Assets/App/XDTBox.ico"
        Height="360"
        Width="560"
        MinHeight="320"
        MinWidth="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource XdtBoxWindowBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/XdtBoxTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="App-Einstellungen"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource XdtBoxPrimaryBrush}"/>
            <TextBlock Text="Diese Einstellungen wirken beim nächsten Start bzw. beim Schließen der geöffneten XDTBox-App."
                       Foreground="{StaticResource XdtBoxMutedTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource XdtBoxPanelBackgroundBrush}"
                BorderBrush="{StaticResource XdtBoxBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <StackPanel>
                <CheckBox x:Name="StartMinimizedToTrayCheckBox"
                          Content="App beim Start direkt minimieren und ins Systray legen"
                          Margin="0,0,0,12"/>
                <CheckBox x:Name="AutoStartMonitoringCheckBox"
                          Content="Überwachung der Ordner beim Start automatisch starten"
                          Margin="0,0,0,12"/>
                <CheckBox x:Name="CloseToTrayInsteadOfExitCheckBox"
                          Content="Beim Schließen ins Systray minimieren statt beenden"
                          Margin="0,0,0,12"/>
                <CheckBox x:Name="ConfirmExitWhileMonitoringCheckBox"
                          Content="Bestätigung anzeigen, wenn bei laufender Überwachung beendet werden soll"
                          Margin="0,0,0,12"/>
                <TextBlock Text="Hinweis: Es wird kein Windows-Autostart, kein Dienst und kein FileSystemWatcher aktiviert. Die Optionen gelten nur, wenn XDTBox normal geöffnet ist."
                           Foreground="{StaticResource XdtBoxMutedTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,16,0,0" LastChildFill="False">
            <Button Content="Abbrechen"
                    Width="120"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    DockPanel.Dock="Right"/>
            <Button Content="Speichern"
                    Width="120"
                    IsDefault="True"
                    Click="Save_Click"
                    DockPanel.Dock="Right"/>
        </DockPanel>
    </Grid>
</Window>
