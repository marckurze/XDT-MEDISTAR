<Window x:Class="XdtDeviceBridge.App.XdtBaukastenSerialCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COM Port abhören"
        Height="560"
        Width="820"
        MinHeight="480"
        MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Icon="Assets/App/XDTBox.ico">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/XdtBoxTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="RS232-Rohdaten für den XDT-Baukasten empfangen"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource XdtBoxDarkTextBrush}" />

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
            <ComboBox x:Name="PortComboBox" Grid.Column="1" MinWidth="120" IsEditable="True" />

            <TextBlock Grid.Column="2" Text="Baud:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,8,0" />
            <TextBox x:Name="BaudRateTextBox" Grid.Column="3" Text="9600" />

            <TextBlock Grid.Column="4" Text="Datenbits:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,8,0" />
            <TextBox x:Name="DataBitsTextBox" Grid.Column="5" Text="8" />

            <TextBlock Grid.Column="6" Text="Dauer:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,8,0" />
            <TextBox x:Name="DurationSecondsTextBox" Grid.Column="7" Text="5" />

            <Button Grid.Column="8"
                    Content="Ports aktualisieren"
                    Margin="16,0,8,0"
                    Click="RefreshPorts_Click" />
            <Button x:Name="ListenButton"
                    Grid.Column="9"
                    Content="Abhören"
                    Click="Listen_Click" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Parität:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,8,8,0" />
            <ComboBox x:Name="ParityComboBox" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" />

            <TextBlock Grid.Row="1" Grid.Column="2" Text="Stoppbits:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,8,8,0" />
            <ComboBox x:Name="StopBitsComboBox" Grid.Row="1" Grid.Column="3" Margin="0,8,0,0" />

            <TextBlock Grid.Row="1" Grid.Column="4" Text="Fluss:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,8,8,0" />
            <ComboBox x:Name="HandshakeComboBox" Grid.Row="1" Grid.Column="5" Grid.ColumnSpan="2" Margin="0,8,0,0" />

            <TextBlock Grid.Row="1" Grid.Column="7" Text="Zeilenende:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,8,8,0" />
            <ComboBox x:Name="LineTerminatorComboBox" Grid.Row="1" Grid.Column="8" Grid.ColumnSpan="2" Margin="0,8,0,0" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Rohtext">
                <TextBox x:Name="RawTextBox"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         TextWrapping="NoWrap" />
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Hexdump">
                <TextBox x:Name="HexDumpTextBox"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         TextWrapping="NoWrap" />
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource XdtBoxMutedTextBrush}"
                       Text="Bereit." />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Übernehmen in Baukasten"
                        MinWidth="180"
                        Margin="8,0,0,0"
                        Click="Accept_Click" />
                <Button Content="Abbrechen"
                        MinWidth="110"
                        Margin="8,0,0,0"
                        Click="Cancel_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
