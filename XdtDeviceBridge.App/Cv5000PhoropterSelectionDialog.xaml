<Window x:Class="XdtDeviceBridge.App.Cv5000PhoropterSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Werte an Phoropter übergeben"
        Width="900"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,12"
                   Text="Bitte wählen Sie die vorhandenen MEDISTAR-Karteikartenwerte aus, die an TOPCON CV-5000/CV-5000S übergeben werden sollen."
                   TextWrapping="Wrap" />

        <GroupBox Grid.Row="1"
                  Header="Patient"
                  Margin="0,0,0,12">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" FontWeight="SemiBold" Text="Patientennummer:" />
                <TextBlock x:Name="PatientNumberTextBlock" Grid.Row="0" Grid.Column="1" Margin="0,0,24,6" />
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,8,6" FontWeight="SemiBold" Text="Untersuchungsart:" />
                <TextBlock x:Name="ExaminationTypeTextBlock" Grid.Row="0" Grid.Column="3" Margin="0,0,0,6" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" FontWeight="SemiBold" Text="Name:" />
                <TextBlock x:Name="PatientNameTextBlock" Grid.Row="1" Grid.Column="1" Margin="0,0,24,0" />
                <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,8,0" FontWeight="SemiBold" Text="Geburtsdatum:" />
                <TextBlock x:Name="BirthDateTextBlock" Grid.Row="1" Grid.Column="3" />
            </Grid>
        </GroupBox>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="GroupsPanel" />
        </ScrollViewer>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Margin="0,12,0,12"
                   Foreground="#7A5A00"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ExportButton"
                    Width="180"
                    Margin="0,0,12,0"
                    Content="An Phoropter ausgeben"
                    Click="ExportButton_Click" />
            <Button Width="120"
                    Content="Abbrechen"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
