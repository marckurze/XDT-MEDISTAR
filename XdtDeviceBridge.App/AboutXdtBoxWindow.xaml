<Window x:Class="XdtDeviceBridge.App.AboutXdtBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Info"
        Icon="Assets/App/XDTBox.ico"
        Height="360"
        Width="520"
        MinHeight="320"
        MinWidth="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="Assets/Branding/XDTBox_Logo_Schriftzug.png"
                   Height="64"
                   Stretch="Uniform"
                   Margin="0,0,16,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="XDTBox" FontSize="24" FontWeight="Bold"/>
                <TextBlock x:Name="VersionTextBlock" Foreground="DimGray"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Hersteller:" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="Technik-Apparat M.Kurze"/>
            <TextBlock Text="Felsenstraße 4"/>
            <TextBlock Text="90574 Roßtal"/>
            <TextBlock Text="info@XDTBox.com" Margin="0,8,0,0"/>
            <TextBlock Text="www.XDTBox.com"/>
            <TextBlock Text="© Technik-Apparat M.Kurze"
                       Foreground="DimGray"
                       Margin="0,16,0,0"/>
        </StackPanel>

        <Button Grid.Row="2"
                Content="Schließen"
                Width="120"
                HorizontalAlignment="Right"
                IsDefault="True"
                Click="Close_Click"/>
    </Grid>
</Window>
