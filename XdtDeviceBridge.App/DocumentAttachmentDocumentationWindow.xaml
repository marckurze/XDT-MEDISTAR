<Window x:Class="XdtDeviceBridge.App.DocumentAttachmentDocumentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dokumentation erfassen"
        SizeToContent="WidthAndHeight"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16" MinWidth="500">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ProfileNameTextBlock"
                   Grid.Row="0"
                   FontWeight="Bold"
                   FontSize="15"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="Erkannte Dateien werden als XDT-Anhänge übergeben. Der optionale Text wird als 6227 in die XDT-Ausgabe geschrieben."
                   Foreground="DimGray"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="2"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,12">
            <ItemsControl x:Name="FileNamesItemsControl" MaxHeight="120">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" Margin="0,1"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <TextBox x:Name="DocumentationTextBox"
                 Grid.Row="3"
                 MinHeight="90"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 ToolTip="Optionaler Dokumentationstext. Leer lassen, wenn keine 6227-Zeile erzeugt werden soll."/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Übernehmen"
                    Width="110"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Apply_Click"/>
            <Button Content="Ohne Text fortfahren"
                    Width="150"
                    IsCancel="True"
                    Click="ContinueWithoutText_Click"/>
        </StackPanel>
    </Grid>
</Window>
