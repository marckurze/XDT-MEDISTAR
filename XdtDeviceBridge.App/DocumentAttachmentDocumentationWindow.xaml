<Window x:Class="XdtDeviceBridge.App.DocumentAttachmentDocumentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dokumente übertragen"
        Width="760"
        MinWidth="620"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ProfileNameTextBlock"
                   Grid.Row="0"
                   FontWeight="Bold"
                   FontSize="15"
                   Margin="0,0,0,6"/>

        <TextBlock x:Name="HintTextBlock"
                   Grid.Row="1"
                   Text="Prüfen Sie die gefundenen Dateien und ergänzen Sie optional eine Beschreibung je Datei."
                   Foreground="DimGray"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="2"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="420">
                <ItemsControl x:Name="FileItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E5E7EB"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="48"
                                            Height="48"
                                            CornerRadius="6"
                                            Background="#EEF2F7"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding FileFormatLabel}"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Foreground="#334155"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>

                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding FileName}"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding DetailText}"
                                                   Foreground="DimGray"
                                                   FontSize="12"
                                                   Margin="0,2,0,6"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBox Grid.Row="2"
                                                 Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding DescriptionVisibility}"
                                                 MinHeight="54"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 ToolTip="Beschreibung für MEDISTAR-Feld 6304. Ohne Eingabe wird der Originaldateiname verwendet."/>
                                        <TextBlock Grid.Row="3"
                                                   Text="Ohne Eingabe wird der Dateiname verwendet."
                                                   Visibility="{Binding DescriptionVisibility}"
                                                   Foreground="DimGray"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ApplyButton"
                    Content="Übertragen"
                    Width="110"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Apply_Click"/>
            <Button x:Name="CancelButton"
                    Content="Abbrechen"
                    Width="110"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
