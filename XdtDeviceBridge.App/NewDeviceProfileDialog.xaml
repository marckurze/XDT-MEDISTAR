<Window x:Class="XdtDeviceBridge.App.NewDeviceProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Neues Gerät anlegen"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16" MinWidth="460">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Profilname:" FontWeight="Bold" Margin="0,0,8,8"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="ProfileNameTextBox" MinWidth="280" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hersteller:" FontWeight="Bold" Margin="0,0,8,8"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="ManufacturerTextBox" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Modell:" FontWeight="Bold" Margin="0,0,8,8"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="ModelTextBox" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Gerätetyp:" FontWeight="Bold" Margin="0,0,8,8"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="DeviceTypeTextBox" Text="Generisch" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Parserbasis:" FontWeight="Bold" Margin="0,0,8,8"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="ParserModeComboBox" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Speichern" Width="110" Margin="0,0,8,0" IsDefault="True" Click="Save_Click"/>
            <Button Content="Abbrechen" Width="110" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
