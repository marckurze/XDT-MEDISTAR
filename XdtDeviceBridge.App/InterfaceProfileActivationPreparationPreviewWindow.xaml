<Window x:Class="XdtDeviceBridge.App.InterfaceProfileActivationPreparationPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Height="640"
        Width="760"
        MinHeight="420"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Aktivierung vorbereiten"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <Border BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Schnittstellenprofil: " FontWeight="SemiBold"/>
                            <Run Text="{Binding ProfileName}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Status: " FontWeight="SemiBold"/>
                            <Run Text="{Binding StatusText}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Aktivierbar laut Bewertung: " FontWeight="SemiBold"/>
                            <Run Text="{Binding CanActivateText}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap">
                            <Run Text="Zusammenfassung: " FontWeight="SemiBold"/>
                            <Run Text="{Binding BlockerCount}"/>
                            <Run Text=" Blocker, "/>
                            <Run Text="{Binding WarningCount}"/>
                            <Run Text=" Warnungen, "/>
                            <Run Text="{Binding InfoCount}"/>
                            <Run Text=" Hinweise"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <GroupBox Header="Technische Schutzprüfung" Margin="0,0,0,10">
                    <StackPanel Margin="8">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Entscheidung: " FontWeight="SemiBold"/>
                            <Run Text="{Binding GuardDecisionText}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Technisch freigegeben: " FontWeight="SemiBold"/>
                            <Run Text="{Binding GuardCanProceedText}"/>
                        </TextBlock>
                        <TextBlock x:Name="GuardMessageTextBlock"
                                   Text="{Binding GuardMessage}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Warnungsbestätigung" Margin="0,0,0,10">
                    <StackPanel Margin="8">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Status: " FontWeight="SemiBold"/>
                            <Run Text="{Binding WarningConfirmationStatusText}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Bestätigungspflichtige Warnungen: " FontWeight="SemiBold"/>
                            <Run Text="{Binding WarningConfirmationItemCount}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding WarningConfirmationMessage}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>
                        <StackPanel x:Name="WarningConfirmationItemsSection">
                            <TextBlock Text="Später bewusst zu prüfende Warnungen:"
                                       FontWeight="SemiBold"
                                       Margin="0,2,0,4"/>
                            <ItemsControl ItemsSource="{Binding WarningConfirmationItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   Margin="8,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Diese Warnungen wurden in diesem Schritt nicht bestätigt."
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Aktivierungsplan" Margin="0,0,0,10">
                    <StackPanel Margin="8">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Status: " FontWeight="SemiBold"/>
                            <Run Text="{Binding ActivationPlanStatusText}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">
                            <Run Text="Spätere Aktivierung laut Plan möglich: " FontWeight="SemiBold"/>
                            <Run Text="{Binding ActivationPlanCanExecuteLaterText}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding ActivationPlanMessage}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <StackPanel x:Name="ActivationPlanMissingRequirementsSection"
                                    Margin="0,2,0,6">
                            <TextBlock Text="Fehlende Voraussetzungen:"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding ActivationPlanMissingRequirements}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   Margin="8,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="ActivationPlanReasonsSection"
                                    Margin="0,2,0,6">
                            <TextBlock Text="Planhinweise:"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding ActivationPlanReasons}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   Margin="8,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel x:Name="ActivationPlanStepsSection"
                                    Margin="0,2,0,0">
                            <TextBlock Text="Geplante spätere Schritte:"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <ItemsControl ItemsSource="{Binding ActivationPlanSteps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   TextWrapping="Wrap"
                                                   Margin="8,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Diese Schritte wurden in diesem Schritt nicht ausgeführt."
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <Border Background="#FFF7E6"
                        BorderBrush="#E0B45C"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10"
                        Margin="0,0,0,8">
                    <TextBlock Text="{Binding SafetyNotice}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="Weitere Details sind in der Prüfungsübersicht im Hauptfenster sichtbar."
                           Foreground="#666666"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    MinWidth="96"
                    Padding="12,4"
                    IsDefault="True"
                    IsCancel="True"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
