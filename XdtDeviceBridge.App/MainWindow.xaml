                                </Grid>
                            </GroupBox>
                            <TextBlock Grid.Row="4"
                                       Text="Neue AIS-, Geräte- und Exportprofile werden als UserDefined angelegt. BuiltIn-Profile bleiben unverändert."
                                       Foreground="DimGray"
                                       TextWrapping="Wrap"/>
                            <GroupBox Grid.Row="5"
                                      Header="Templatepaket-Importvorschau"
                                      Margin="0,8,0,0">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="180"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="120"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               x:Name="TemplatePackageImportPreviewSummaryText"
                                               Text="Noch kein Templatepaket importiert."
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"/>
                                    <TextBox Grid.Row="1"
                                             x:Name="TemplatePackageImportPreviewMessagesTextBox"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="70"
                                             Margin="0,0,0,8"
                                             Text="Die Vorschau zeigt nach dem Import Validierung, Konfliktanalyse, Importplan und Dry-Run. Es wird nichts gespeichert."/>
                                    <DataGrid Grid.Row="2"
                                              x:Name="TemplatePackageImportPreviewGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              MinHeight="160"
                                              Margin="0,0,0,8">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Profilart" Binding="{Binding ProfileKind}" MinWidth="130" Width="130" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Importierter Name" Binding="{Binding ImportedProfileName}" MinWidth="220" Width="220" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Importierte ID" Binding="{Binding ImportedProfileId}" MinWidth="180" Width="180" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Header="Auswahl" MinWidth="180" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox ItemsSource="{Binding AvailableActions}"
                                                                  SelectedValue="{Binding SelectedAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  SelectedValuePath="Action"
                                                                  DisplayMemberPath="DisplayName"
                                                                  IsEnabled="{Binding IsActionSelectionEnabled}"
                                                                  SelectionChanged="TemplatePackageImportActionComboBox_SelectionChanged"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Geplante Aktion" Binding="{Binding PlannedAction}" MinWidth="160" Width="160" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Header="Zielname" MinWidth="220" Width="220">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding TargetProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding IsTargetNameEditable}"
                                                                 BorderThickness="0"
                                                                 Padding="2"
                                                                 LostFocus="TemplatePackageImportTargetNameTextBox_LostFocus"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Ziel-ID" Binding="{Binding TargetProfileId}" MinWidth="180" Width="180" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Konflikt" Binding="{Binding Conflict}" MinWidth="150" Width="150" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" MinWidth="90" Width="90" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Meldung" Binding="{Binding Message}" MinWidth="320" Width="*" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <StackPanel Grid.Row="3" Margin="0,0,0,4">
                                        <TextBlock Text="Abhängigkeitsauflösung für Schnittstellenprofile"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="Schnittstellenprofile verknüpfen AIS-, Geräte- und Exportprofile. Diese Tabelle zeigt, auf welche Zielprofile die Verweise nach dem Import zeigen. Fehlende Zielprofile müssen vor einer späteren Nutzung behoben werden."
                                                   Foreground="DimGray"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <DataGrid Grid.Row="4"
                                              x:Name="TemplatePackageImportDependencyPreviewGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              MinHeight="110">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Schnittstellenprofil" Binding="{Binding InterfaceProfileName}" MinWidth="220" Width="220"/>
                                            <DataGridTextColumn Header="Abhängigkeit" Binding="{Binding DependencyKind}" MinWidth="130" Width="130"/>
                                            <DataGridTextColumn Header="Originalname" Binding="{Binding OriginalProfileName}" MinWidth="180" Width="180"/>
                                            <DataGridTextColumn Header="Original-ID" Binding="{Binding OriginalProfileId}" MinWidth="180" Width="180"/>
                                            <DataGridTextColumn Header="Zielname" Binding="{Binding TargetProfileName}" MinWidth="180" Width="180"/>
                                            <DataGridTextColumn Header="Ziel-ID" Binding="{Binding TargetProfileId}" MinWidth="180" Width="180"/>
                                            <DataGridTextColumn Header="Auflösung" Binding="{Binding Resolution}" MinWidth="180" Width="180"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" MinWidth="90" Width="90"/>
                                            <DataGridTextColumn Header="Meldung" Binding="{Binding Message}" MinWidth="320" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Grid.Row="4"
                                               x:Name="TemplatePackageImportDependencyEmptyText"
                                               Visibility="Collapsed"
                                               Foreground="DimGray"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Margin="4"/>
                                    <WrapPanel Grid.Row="5" Margin="0,8,0,8">
                                        <Button x:Name="ExecuteTemplatePackageImportButton"
                                                Content="Import als UserDefined übernehmen"
                                                Width="260"
                                                IsEnabled="False"
                                                Margin="0,0,12,0"
                                                Click="ExecuteTemplatePackageImport_Click"/>
                                        <TextBlock Text="Explizite Übernahme: nur ImportAsNew/ImportAsCopy. Kein Überschreiben, keine BuiltIn-Änderung, keine automatische Aktivierung."
                                                   Foreground="DarkOrange"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </WrapPanel>
                                    <TextBox Grid.Row="6"
                                             x:Name="TemplatePackageImportExecutionResultTextBox"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="100"
                                             Text="Noch keine Importübernahme ausgeführt."/>
                                </Grid>
                            </GroupBox>
                        </Grid>
                        </Expander>

                        <Expander Header="Profilnamen" IsExpanded="True" Grid.Row="2" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Geräte" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Exportprofile" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="Schnittstellen" FontWeight="Bold" Margin="0,0,0,4"/>

                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         x:Name="AisProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         x:Name="DeviceProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="4"
                                         x:Name="ExportProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="6"
                                         x:Name="InterfaceProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Expander>

                        <Expander Header="Exportregeln" IsExpanded="True" Grid.Row="3" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="260"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Exportprofil:"
                                           FontWeight="Bold"
                                           Margin="0,0,8,8"
                                           ToolTip="Legt fest, wie AIS-Daten und Gerätewerte in eine Rückgabedatei geschrieben werden."/>
                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <ComboBox Grid.Column="0"
                                               x:Name="ExportProfileComboBox"
                                               DisplayMemberPath="Metadata.Name"
                                               MinWidth="360"
                                              Margin="0,0,8,0"
                                              ToolTip="Legt fest, wie AIS-Daten und Gerätewerte in eine Rückgabedatei geschrieben werden."
                                              SelectionChanged="ExportProfileComboBox_SelectionChanged"/>
                                     <Button Grid.Column="1"
                                             Content="Neue Exportregel"
                                             Width="150"
                                             Margin="0,0,8,0"
                                             Click="AddDraftExportRule_Click"/>
                                     <Button Grid.Column="2"
                                             x:Name="RemoveExportRuleButton"
                                             Content="Exportregel entfernen"
                                             Width="170"
                                             Click="RemoveSelectedExportRule_Click"
                                             ToolTip="Entfernt eine ausgewählte Regel nur aus einem UserDefined-Exportprofil."
                                             ToolTipService.ShowOnDisabled="True"/>
                                 </Grid>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           x:Name="ExportRulesStatusText"
                                           Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="2"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          x:Name="ExportRulesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          MinHeight="260"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          SelectionChanged="ExportRulesGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding SortOrder}" Width="80">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="SortOrder" ToolTip="Reihenfolge der Ausgabezeilen in der erzeugten XDT-Datei."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding TargetFieldCode}" Width="120">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="TargetFieldCode" ToolTip="XDT/GDT-Feldkennung, in die der Wert geschrieben wird, z. B. 6228 für Ergebnistext."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding TargetName}" Width="160">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="TargetName" ToolTip="Interner Anzeigename der Exportregel."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding RuleType}" Width="110">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="RuleType" ToolTip="Art der Regel: fester Wert, AIS-Feld, Gerätewert oder zusammengesetztes Template."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding SourcePath}" Width="220">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="SourcePath" ToolTip="Quelle des Werts, z. B. AIS.PatientNumber oder Device.R/AR/ARMedian/Sphere."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding OutputTemplate}" Width="420">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="OutputTemplate" ToolTip="Ausgabeformat. Platzhalter werden in geschweiften Klammern geschrieben, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridCheckBoxColumn Binding="{Binding IsEnabled}" Width="90">
                                            <DataGridCheckBoxColumn.Header>
                                                <TextBlock Text="IsEnabled" ToolTip="Legt fest, ob diese Regel beim Export berücksichtigt wird."/>
                                            </DataGridCheckBoxColumn.Header>
                                        </DataGridCheckBoxColumn>
                                        <DataGridTextColumn Binding="{Binding Description}" Width="260">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="Description" ToolTip="Beschreibung oder Hinweis zur Regel."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
