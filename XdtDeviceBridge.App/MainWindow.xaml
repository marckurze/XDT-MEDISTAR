<Window x:Class="XdtDeviceBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XdtDeviceBridge"
        Height="900"
        Width="1200"
        MinHeight="800"
        MinWidth="1200">
    <Grid Margin="12">
        <TabControl>
            <TabItem Header="Verarbeitung">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8" MinHeight="700">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="3*"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Aktive Schnittstellenprofile" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="220"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="170"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="Diese Übersicht zeigt vorbereitete Schnittstellen für die spätere automatische Ordnerverarbeitung. Die automatische Verarbeitung ist noch nicht aktiv."
                                           Foreground="DimGray"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1"
                                           x:Name="ActiveInterfaceProfilesStatusText"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                                    <Button x:Name="ActiveProfileScanButton"
                                            Content="Aktive Profile einmalig scannen"
                                            Width="240"
                                            Margin="0,0,8,8"
                                            Click="ScanActiveProfilesOnce_Click"/>
                                    <Button x:Name="StartPeriodicScanButton"
                                            Content="Überwachung starten"
                                            Width="170"
                                            Margin="0,0,8,8"
                                            Click="StartPeriodicScan_Click"/>
                                    <Button x:Name="StopPeriodicScanButton"
                                            Content="Überwachung stoppen"
                                            Width="170"
                                            IsEnabled="False"
                                            Margin="0,0,16,8"
                                            Click="StopPeriodicScan_Click"/>
                                    <TextBlock Text="Status:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock x:Name="PeriodicScanStatusText" Text="Gestoppt" MinWidth="80" Margin="0,3,16,8"/>
                                    <TextBlock Text="Intervall:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock Text="5 Sekunden" MinWidth="80" Margin="0,3,16,8"/>
                                    <TextBlock Text="Letzter Scan:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock x:Name="PeriodicScanLastRunText" Text="-" MinWidth="130" Margin="0,3,16,8"/>
                                    <TextBlock Text="Fertige Paare letzter Scan:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock x:Name="PeriodicScanReadyPairsText" Text="0" MinWidth="40" Margin="0,3,0,8"/>
                                    <CheckBox x:Name="EnableAutomaticPairProcessingCheckBox"
                                              Content="Gefundene Dateipaare automatisch verarbeiten"
                                              Margin="0,3,16,8"/>
                                    <TextBlock Text="Automatische Verarbeitung erfolgt nur während der manuell gestarteten Überwachung. Importdateien werden nicht gelöscht oder verschoben."
                                               Foreground="DarkRed"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,8"/>
                                </WrapPanel>
                                <DataGrid Grid.Row="3"
                                          x:Name="ActiveInterfaceProfilesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          MinHeight="180">
                                    <DataGrid.Resources>
                                        <Style x:Key="TrimmedCellTextStyle" TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" MinWidth="220" Width="220">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TrimmedCellTextStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding Name}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="AIS" Binding="{Binding AisName}" MinWidth="140" Width="140"/>
                                        <DataGridTextColumn Header="Gerät" Binding="{Binding DeviceName}" MinWidth="160" Width="160"/>
                                        <DataGridTextColumn Header="Exportprofil" Binding="{Binding ExportProfileName}" MinWidth="220" Width="220">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TrimmedCellTextStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding ExportProfileName}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="AIS-Importordner" Binding="{Binding AisImportFolder}" MinWidth="240" Width="240">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TrimmedCellTextStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding AisImportFolder}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Geräte-Importordner" Binding="{Binding DeviceImportFolder}" MinWidth="240" Width="240">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TrimmedCellTextStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding DeviceImportFolder}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Exportordner" Binding="{Binding ExportFolder}" MinWidth="240" Width="240">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TrimmedCellTextStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding ExportFolder}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Lizenz" Binding="{Binding LicenseStatus}" MinWidth="160" Width="160"/>
                                        <DataGridTextColumn Header="Ordnerstatus" Binding="{Binding FolderStatus}" MinWidth="220" Width="220">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TrimmedCellTextStyle}">
                                                    <Setter Property="ToolTip" Value="{Binding FolderStatus}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Status" Binding="{Binding ProcessingStatus}" MinWidth="220" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Grid.Row="4"
                                           Text="Scan-Ergebnis"
                                           FontWeight="Bold"
                                           Margin="0,8,0,4"/>
                                <TextBox Grid.Row="5"
                                         x:Name="ActiveProfileScanResultTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap"
                                         MinHeight="120"
                                         Text="Noch kein Scan ausgeführt."/>
                                <TextBlock Grid.Row="6"
                                           Text="Gefundene Dateipaare"
                                           FontWeight="Bold"
                                           Margin="0,8,0,4"/>
                                <DataGrid Grid.Row="7"
                                          x:Name="ScannedImportPairsGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          MinHeight="140"
                                          SelectionChanged="ScannedImportPairsGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Schnittstellenprofil" Binding="{Binding InterfaceProfileName}" MinWidth="220" Width="220"/>
                                        <DataGridTextColumn Header="AIS-Datei" Binding="{Binding AisFilePath}" MinWidth="260" Width="260"/>
                                        <DataGridTextColumn Header="Gerätedatei" Binding="{Binding DeviceFilePath}" MinWidth="260" Width="260"/>
                                        <DataGridTextColumn Header="Exportordner" Binding="{Binding ExportFolder}" MinWidth="240" Width="240"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" MinWidth="160" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button Grid.Row="8"
                                        x:Name="ProcessSelectedImportPairButton"
                                        Content="Ausgewähltes Paar verarbeiten"
                                        Width="240"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0"
                                        IsEnabled="False"
                                        Click="ProcessSelectedImportPair_Click"/>
                            </Grid>
                        </GroupBox>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="AIS-GDT-Datei auswählen" Margin="0,0,8,0" Click="SelectAisFile_Click" />
                            <TextBox Grid.Column="1" x:Name="AisFilePathTextBox" IsReadOnly="True" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="NIDEK-XML-Datei auswählen" Margin="0,0,8,0" Click="SelectDeviceFile_Click" />
                            <TextBox Grid.Column="1" x:Name="DeviceFilePathTextBox" IsReadOnly="True" />
                        </Grid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Verarbeiten" Width="150" Margin="0,0,8,0" Click="Process_Click" />
                            <Button Content="Exportdatei schreiben" Width="180" Click="Export_Click" />
                        </StackPanel>

                        <GroupBox Header="Patientendaten" Grid.Row="4" Margin="0,0,0,8">
                            <UniformGrid Columns="4" Margin="8">
                                <TextBlock Text="PatientNumber:" FontWeight="Bold"/>
                                <TextBlock x:Name="PatientNumberText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="LastName:" FontWeight="Bold"/>
                                <TextBlock x:Name="LastNameText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="FirstName:" FontWeight="Bold"/>
                                <TextBlock x:Name="FirstNameText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="BirthDate:" FontWeight="Bold"/>
                                <TextBlock x:Name="BirthDateText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Street:" FontWeight="Bold"/>
                                <TextBlock x:Name="StreetText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="PostalCodeCity:" FontWeight="Bold"/>
                                <TextBlock x:Name="PostalCodeCityText" TextTrimming="CharacterEllipsis"/>
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Header="Messwerte" Grid.Row="5" Margin="0,0,0,0">
                            <DataGrid x:Name="MeasurementsGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="SourcePath" Binding="{Binding SourcePath}" Width="*"/>
                                    <DataGridTextColumn Header="Eye" Binding="{Binding Eye}" Width="80"/>
                                    <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120"/>
                                    <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="140"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100"/>
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GridSplitter Grid.Row="6"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <GroupBox Header="Exportvorschau" Grid.Row="7" Margin="0,0,0,0">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="PlannedFileNameText" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBox x:Name="ExportPreviewTextBox"
                                         Grid.Row="1"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap"
                                         MinHeight="180"/>
                            </Grid>
                        </GroupBox>

                        <GridSplitter Grid.Row="8"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <GroupBox Header="Meldungen" Grid.Row="9">
                            <TextBox x:Name="MessagesTextBox"
                                     Margin="8"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     MinHeight="120"/>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Profile &amp; Templates">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Expander Header="Profilübersicht" IsExpanded="True" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AisProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Geräte:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="DeviceProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Export:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" x:Name="ExportProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="Schnittstellen:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="7" x:Name="InterfaceProfileCountText" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="BaseFolder:" FontWeight="Bold" Margin="0,0,4,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="7" x:Name="ProfileBaseFolderText" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Expander>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <WrapPanel Grid.Row="0">
                                <Button Content="Templatepaket exportieren" Width="190" Margin="0,0,8,8" Click="ExportTemplatePackage_Click"/>
                                <Button Content="Templatepaket importieren" Width="190" Margin="0,0,16,8" Click="ImportTemplatePackage_Click"/>
                                <Button Content="Neues AIS anlegen" Width="160" Margin="0,0,8,8" Click="ProfileAssistantPlaceholder_Click"/>
                                <Button Content="Neues Gerät anlegen" Width="170" Margin="0,0,8,8" Click="ProfileAssistantPlaceholder_Click"/>
                                <Button Content="Neues Exportprofil anlegen" Width="200" Margin="0,0,8,8" Click="ProfileAssistantPlaceholder_Click"/>
                            </WrapPanel>
                            <TextBlock Grid.Row="1"
                                       Text="Neue Geräte- und AIS-Profile werden später über einen Profil-Assistenten erstellt."
                                       Foreground="DimGray"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Expander Header="Profilnamen" IsExpanded="True" Grid.Row="2" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Geräte" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Exportprofile" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="Schnittstellen" FontWeight="Bold" Margin="0,0,0,4"/>

                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         x:Name="AisProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         x:Name="DeviceProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="4"
                                         x:Name="ExportProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="6"
                                         x:Name="InterfaceProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Expander>

                        <Expander Header="Exportregeln" IsExpanded="True" Grid.Row="3" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="260"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Exportprofil:"
                                           FontWeight="Bold"
                                           Margin="0,0,8,8"
                                           ToolTip="Legt fest, wie AIS-Daten und Gerätewerte in eine Rückgabedatei geschrieben werden."/>
                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              x:Name="ExportProfileComboBox"
                                              DisplayMemberPath="Metadata.Name"
                                              MinWidth="360"
                                              Margin="0,0,8,0"
                                              ToolTip="Legt fest, wie AIS-Daten und Gerätewerte in eine Rückgabedatei geschrieben werden."
                                              SelectionChanged="ExportProfileComboBox_SelectionChanged"/>
                                    <Button Grid.Column="1"
                                            Content="Neue Exportregel"
                                            Width="150"
                                            Click="AddDraftExportRule_Click"/>
                                </Grid>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           x:Name="ExportRulesStatusText"
                                           Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="2"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          x:Name="ExportRulesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          MinHeight="260"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          SelectionChanged="ExportRulesGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding SortOrder}" Width="80">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="SortOrder" ToolTip="Reihenfolge der Ausgabezeilen in der erzeugten XDT-Datei."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding TargetFieldCode}" Width="120">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="TargetFieldCode" ToolTip="XDT/GDT-Feldkennung, in die der Wert geschrieben wird, z. B. 6228 für Ergebnistext."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding TargetName}" Width="160">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="TargetName" ToolTip="Interner Anzeigename der Exportregel."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding RuleType}" Width="110">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="RuleType" ToolTip="Art der Regel: fester Wert, AIS-Feld, Gerätewert oder zusammengesetztes Template."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding SourcePath}" Width="220">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="SourcePath" ToolTip="Quelle des Werts, z. B. AIS.PatientNumber oder Device.R/AR/ARMedian/Sphere."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding OutputTemplate}" Width="420">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="OutputTemplate" ToolTip="Ausgabeformat. Platzhalter werden in geschweiften Klammern geschrieben, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridCheckBoxColumn Binding="{Binding IsEnabled}" Width="90">
                                            <DataGridCheckBoxColumn.Header>
                                                <TextBlock Text="IsEnabled" ToolTip="Legt fest, ob diese Regel beim Export berücksichtigt wird."/>
                                            </DataGridCheckBoxColumn.Header>
                                        </DataGridCheckBoxColumn>
                                        <DataGridTextColumn Binding="{Binding Description}" Width="260">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="Description" ToolTip="Beschreibung oder Hinweis zur Regel."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <GridSplitter Grid.Row="3"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              Height="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ShowsPreview="True"/>
                                <DockPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <Button DockPanel.Dock="Right"
                                            Content="Entwurf als neues Exportprofil speichern"
                                            Width="260"
                                            Margin="8,0,0,0"
                                            Click="SaveDraftAsNewExportProfile_Click"
                                            ToolTip="Speichert den aktuellen Entwurf als neues benutzerdefiniertes Exportprofil. Das ausgewählte Originalprofil wird nicht überschrieben."/>
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Neuer Profilname:"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBox x:Name="NewExportProfileNameTextBox"
                                             MinWidth="360"
                                             ToolTip="Name für das neue Exportprofil. Das Originalprofil bleibt unverändert."/>
                                </DockPanel>
                            </Grid>
                        </Expander>

                        <GridSplitter Grid.Row="4"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <Expander Header="Exportregel-Entwurf" IsExpanded="True" Grid.Row="5" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="Auto"/>
                                 </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="4"
                                           x:Name="DraftModeStatusText"
                                           Text="Entwurfsmodus: Änderungen und neue Regeln werden noch nicht gespeichert."
                                           FontWeight="Bold"
                                           Foreground="DarkRed"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TargetFieldCode:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="XDT/GDT-Feldkennung, in die der Wert geschrieben wird, z. B. 6228 für Ergebnistext."/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="DraftTargetFieldCodeTextBox" Margin="0,0,16,8" ToolTip="XDT/GDT-Feldkennung, in die der Wert geschrieben wird, z. B. 6228 für Ergebnistext."/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="TargetName:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Interner Anzeigename der Exportregel."/>
                                <TextBox Grid.Row="1" Grid.Column="3" x:Name="DraftTargetNameTextBox" Margin="0,0,0,8" ToolTip="Interner Anzeigename der Exportregel."/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="RuleType:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Art der Regel: fester Wert, AIS-Feld, Gerätewert oder zusammengesetztes Template."/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DraftRuleTypeComboBox" Margin="0,0,16,8" ToolTip="Art der Regel: fester Wert, AIS-Feld, Gerätewert oder zusammengesetztes Template."/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="SortOrder:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Reihenfolge der Ausgabezeilen in der erzeugten XDT-Datei."/>
                                <TextBox Grid.Row="2" Grid.Column="3" x:Name="DraftSortOrderTextBox" Margin="0,0,0,8" ToolTip="Reihenfolge der Ausgabezeilen in der erzeugten XDT-Datei."/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="SourcePath:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Quelle des Werts, z. B. AIS.PatientNumber oder Device.R/AR/ARMedian/Sphere."/>
                                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" x:Name="DraftSourcePathTextBox" Margin="0,0,0,8" ToolTip="Quelle des Werts, z. B. AIS.PatientNumber oder Device.R/AR/ARMedian/Sphere."/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="OutputTemplate:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Ausgabeformat. Platzhalter werden in geschweiften Klammern geschrieben, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}."/>
                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         x:Name="DraftOutputTemplateTextBox"
                                         MinHeight="80"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                          ToolTip="Ausgabeformat. Platzhalter werden in geschweiften Klammern geschrieben, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}."
                                         TextChanged="DraftOutputTemplateTextBox_TextChanged"
                                         Margin="0,0,0,8"/>
                                <CheckBox Grid.Row="5" Grid.Column="1" x:Name="DraftIsEnabledCheckBox" Content="IsEnabled" VerticalAlignment="Center" Margin="0,0,16,0" ToolTip="Legt fest, ob diese Regel beim Export berücksichtigt wird."/>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="Description:" FontWeight="Bold" Margin="0,0,8,0" ToolTip="Beschreibung oder Hinweis zur Regel."/>
                                <DockPanel Grid.Row="5" Grid.Column="3">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button Content="Entwurfsvorschau aktualisieren" Width="210" Margin="0,0,8,0" Click="UpdateDraftPreview_Click"/>
                                        <Button Content="Entwurf zurücksetzen" Width="160" Click="ResetDraft_Click"/>
                                    </StackPanel>
                                    <TextBox x:Name="DraftDescriptionTextBox" ToolTip="Beschreibung oder Hinweis zur Regel."/>
                                </DockPanel>
                            </Grid>
                        </Expander>

                        <GridSplitter Grid.Row="6"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <Expander Header="Regelvorschau" IsExpanded="True" Grid.Row="7" Margin="0,0,0,8">
                            <TextBox x:Name="ExportRulePreviewTextBox"
                                     Margin="8"
                                     MinHeight="150"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Expander>

                        <GridSplitter Grid.Row="8"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <Expander Header="Gesamtexport-Vorschau" IsExpanded="True" Grid.Row="9" Margin="0,0,0,8">
                            <TextBox x:Name="FullExportPreviewTextBox"
                                     Margin="8"
                                     MinHeight="220"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Expander>

                        <GridSplitter Grid.Row="10"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <Expander Header="Verfügbare Platzhalter"
                                  IsExpanded="True"
                                  Grid.Row="11"
                                  Margin="0,0,0,8"
                                  ToolTip="Diese Werte können in OutputTemplates verwendet werden. Platzhalter müssen mit geschweiften Klammern geschrieben werden.">
                            <Grid Margin="8" MaxHeight="460">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="190"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8">
                                    Platzhalter müssen mit geschweiften Klammern geschrieben werden, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}. Runde Klammern wie (Device.Date) werden nicht ersetzt.
                                    Über die Checkbox "Verwenden" kann ein Platzhalter in den aktuellen Entwurf eingefügt oder daraus entfernt werden. Der Ergebnistext bleibt weiterhin frei editierbar.
                                </TextBlock>
                                <TextBlock Grid.Row="1" Text="AIS-Platzhalter" FontWeight="Bold" Margin="0,0,0,4"/>
                                <DataGrid Grid.Row="2"
                                          x:Name="AisPlaceholdersGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasValue}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Platzhalter" Binding="{Binding Placeholder}" Width="230" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Name Messwert" Binding="{Binding DisplayName}" Width="180" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Ausgelesener Wert" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                                        <DataGridTemplateColumn Header="Ausgabeart" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding OutputModes}"
                                                              SelectedItem="{Binding OutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectionChanged="PlaceholderOutputModeComboBox_SelectionChanged"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Verwenden" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsUsed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              Checked="PlaceholderUseCheckBox_Changed"
                                                              Unchecked="PlaceholderUseCheckBox_Changed"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <GridSplitter Grid.Row="3"
                                              Height="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ShowsPreview="True"/>

                                <TextBlock Grid.Row="4" x:Name="DevicePlaceholdersStatusText" Text="Device-Platzhalter" FontWeight="Bold" Margin="0,8,0,4"/>
                                <DataGrid Grid.Row="5"
                                          x:Name="DevicePlaceholdersGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasValue}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Platzhalter" Binding="{Binding Placeholder}" Width="260" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Name Messwert" Binding="{Binding DisplayName}" Width="230" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Ausgelesener Wert" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                                        <DataGridTemplateColumn Header="Ausgabeart" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding OutputModes}"
                                                              SelectedItem="{Binding OutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectionChanged="PlaceholderOutputModeComboBox_SelectionChanged"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Verwenden" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsUsed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              Checked="PlaceholderUseCheckBox_Changed"
                                                              Unchecked="PlaceholderUseCheckBox_Changed"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Expander>

                        <GroupBox Header="Profil- und Template-Meldungen" Grid.Row="12">
                            <TextBox x:Name="ProfileMessagesTextBox"
                                     Margin="8"
                                     MinHeight="160"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Schnittstellenprofile">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Hier wird später gesteuert, welche Schnittstelle automatisch über Ordner verarbeitet wird. In diesem Schritt werden nur Einstellungen gespeichert. Es findet noch keine automatische Ordnerüberwachung statt."
                                   Foreground="DimGray"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <GroupBox Header="Schnittstellenprofil / Automatische Verarbeitung" Grid.Row="1">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Schnittstellenprofil:" FontWeight="Bold" Margin="0,0,8,8"/>
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          x:Name="InterfaceProfileComboBox"
                                          DisplayMemberPath="Metadata.Name"
                                          MinWidth="260"
                                          MaxWidth="560"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,8"
                                          ToolTip="{Binding SelectedItem.Metadata.Name, RelativeSource={RelativeSource Self}}"
                                          SelectionChanged="InterfaceProfileComboBox_SelectionChanged"/>
                                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="0,0,0,8">
                                    <Button Content="Neues Schnittstellenprofil anlegen (später)"
                                            Width="260"
                                            Margin="0,0,8,8"
                                            Click="ProfileAssistantPlaceholder_Click"/>
                                    <Button Content="Schnittstellenprofil für ausgewähltes Exportprofil erstellen"
                                            Width="360"
                                            Margin="0,0,8,8"
                                            Click="CreateInterfaceProfileForSelectedExport_Click"/>
                                    <Button Content="Schnittstellenprofil entfernen"
                                            Width="210"
                                            Margin="0,0,8,8"
                                            Click="RemoveInterfaceProfile_Click"/>
                                    <Button Content="Speichern"
                                            Width="220"
                                            Margin="0,0,0,8"
                                            Click="SaveInterfaceProfile_Click"/>
                                </WrapPanel>

                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS-Profil:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InterfaceAisProfileText" Margin="0,0,0,6" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Geräteprofil:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InterfaceDeviceProfileText" Margin="0,0,0,6" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Exportprofil:" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InterfaceExportProfileText" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                </Grid>

                                <WrapPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <CheckBox x:Name="InterfaceIsActiveCheckBox" Content="Für automatische Verarbeitung aktiv" Margin="0,0,24,8"/>
                                    <CheckBox x:Name="InterfaceIsLicenseRequiredCheckBox" Content="Lizenzpflichtig" Margin="0,0,24,8"/>
                                </WrapPanel>

                                <GroupBox Header="Ordner" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="96"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS-Importordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="InterfaceAisImportFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="AisImport" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Geräte-Importordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="InterfaceDeviceImportFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="1" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="DeviceImport" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Exportordner ans AIS:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="InterfaceExportFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="Export" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Archivordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="InterfaceArchiveFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="3" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="Archive" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Fehlerordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="InterfaceErrorFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="4" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="Error" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="GA-Dateianhang Import (optional):" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="5"
                                                 Grid.Column="1"
                                                 x:Name="InterfaceAttachmentImportFolderTextBox"
                                                 Margin="0,0,8,8"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 ToolTip="Optionaler Ordner für Geräte-Dateianhänge. UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="5" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="AttachmentImport" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="GA-Dateianhang Export (optional):" FontWeight="Bold" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="6"
                                                 Grid.Column="1"
                                                 x:Name="InterfaceAttachmentExportFolderTextBox"
                                                 Margin="0,0,8,0"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 ToolTip="Optionaler Zielordner für umbenannte Geräte-Dateianhänge und spätere externe AIS-Links. UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="6" Grid.Column="2" Content="Auswählen" Width="90" Tag="AttachmentExport" Click="SelectInterfaceFolder_Click"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Ordnerbereinigung" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <StackPanel Margin="8">
                                        <TextBlock Text="Ordnerbereinigung ist gefährlich. Es werden später nur explizit konfigurierte Arbeitsordner bereinigt. Root-, System- und Benutzerprofilordner sind nicht erlaubt. In diesem Schritt wird nur konfiguriert, nicht gelöscht."
                                                   Foreground="DarkRed"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <WrapPanel>
                                            <CheckBox x:Name="InterfaceClearAisImportFolderCheckBox"
                                                      Content="Bereits verarbeitete AIS-Dateien aus Importordner entfernen"
                                                      Margin="0,0,16,8"
                                                      ToolTip="Entfernen bedeutet: Dateien werden sicher ins Archiv verschoben, wenn sie bereits verarbeitet oder als Duplikat erkannt wurden. Es werden keine unbekannten neuen Dateien gelöscht."/>
                                            <CheckBox x:Name="InterfaceClearDeviceImportFolderCheckBox"
                                                      Content="Bereits verarbeitete Gerätedateien aus Importordner entfernen"
                                                      Margin="0,0,16,8"
                                                      ToolTip="Entfernen bedeutet: Dateien werden sicher ins Archiv verschoben, wenn sie bereits verarbeitet oder als Duplikat erkannt wurden. Es werden keine unbekannten neuen Dateien gelöscht."/>
                                            <CheckBox x:Name="InterfaceArchiveProcessedFilesCheckBox" Content="verarbeitete Dateien archivieren" Margin="0,0,16,8"/>
                                            <CheckBox x:Name="InterfaceMoveFailedFilesToErrorFolderCheckBox" Content="fehlerhafte Dateien in Fehlerordner verschieben" Margin="0,0,16,8"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Archivierung" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Archivierungsmodus:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <ComboBox Grid.Row="0"
                                                  Grid.Column="1"
                                                  x:Name="InterfaceArchiveModeComboBox"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="Copy"
                                                  Width="220"
                                                  HorizontalAlignment="Left"
                                                  Margin="0,0,0,8"
                                                  ToolTip="Beim Modus 'Verschieben' werden verarbeitete Importdateien nach erfolgreicher Verarbeitung aus den Importordnern entfernt und ins Archiv verschoben. Dadurch wird eine erneute Verarbeitung derselben Dateien vermieden.">
                                            <ComboBoxItem Content="Kopieren" Tag="Copy"/>
                                            <ComboBoxItem Content="Verschieben" Tag="Move"/>
                                        </ComboBox>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Archiv löschen nach Tagen:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 x:Name="InterfaceArchiveRetentionDaysTextBox"
                                                 Width="120"
                                                 HorizontalAlignment="Left"
                                                 Margin="0,0,0,8"
                                                 ToolTip="Leer oder 0 bedeutet: keine automatische Löschung. Positive Zahlen konfigurieren die Aufbewahrungsfrist in Tagen."/>

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Text="Automatische Löschung betrifft nur den Archivordner und wird erst nach Ablauf der konfigurierten Aufbewahrungsfrist vorgesehen. Import-, Export- und Fehlerordner werden dadurch nicht bereinigt."
                                                   Foreground="DarkOrange"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </GroupBox>
                             </Grid>
                         </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Lizenz">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Lizenzstatus" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Installation-ID:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="LicenseInstallationIdText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Computername:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LicenseMachineNameText" TextTrimming="CharacterEllipsis" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Benutzername:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="LicenseUserNameText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Terminalserver:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LicenseTerminalServerText" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Lizenzstatus:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="LicenseStatusText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Aktive Geräte:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LicenseActiveDeviceCountText" Margin="0,0,16,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Lizenzierte Geräte:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" x:Name="LicenseLicensedDeviceCountText"/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Lizenzanfrage exportieren" Width="190" Margin="0,0,8,0" Click="ExportLicenseRequest_Click"/>
                            <Button Content="Lizenzdatei importieren" Width="190" Margin="0,0,8,0" Click="ImportLicenseFile_Click"/>
                            <Button Content="Karenzzeiten aktualisieren" Width="210" Click="UpdateGracePeriods_Click"/>
                        </StackPanel>

                        <GroupBox Header="Lizenzierte Geräte / Anbindungen" Grid.Row="2" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="340"/>
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                                    <TextBlock Text="Lizenzpflichtige Anbindungen gesamt:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceTotalCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Aktive lizenzpflichtige Anbindungen:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceActiveCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Lizenzierte Geräteanzahl:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceLicensedCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Gedeckt:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceCoveredCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Nicht gedeckt:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceUncoveredCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="In Karenzzeit:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceGraceCountText" MinWidth="36" Margin="0,0,0,6"/>
                                </WrapPanel>

                                <TextBlock Grid.Row="1"
                                           x:Name="LicensedDeviceStatusText"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>

                                <DataGrid Grid.Row="2"
                                          x:Name="LicensedDeviceStatesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          MinHeight="250">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" MinWidth="320" Width="*"/>
                                        <DataGridTextColumn Header="Aktiv" Binding="{Binding AktivText}" MinWidth="70" Width="70"/>
                                        <DataGridTextColumn Header="Lizenzpflichtig" Binding="{Binding LizenzpflichtigText}" MinWidth="110" Width="110"/>
                                        <DataGridTextColumn Header="Gedeckt" Binding="{Binding GedecktText}" MinWidth="90" Width="90"/>
                                        <DataGridTextColumn Header="Karenz" Binding="{Binding KarenzText}" MinWidth="90" Width="90"/>
                                        <DataGridTextColumn Header="Karenz bis" Binding="{Binding KarenzBisText}" MinWidth="140" Width="140"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" MinWidth="420" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Lizenzmeldungen" Grid.Row="3">
                            <TextBox x:Name="LicenseMessagesTextBox"
                                     Margin="8"
                                     MinHeight="280"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
