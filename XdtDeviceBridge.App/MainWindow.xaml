                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <Expander Header="Test &amp; Vorschau" IsExpanded="True" Grid.Row="9" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Hier können AIS-Datei, Gerätedatei und optionaler XDT-Anhang manuell geladen werden, um Messwerte und XDT-Exportvorschau für das ausgewählte Profil zu prüfen."
