<Window x:Class="XdtDeviceBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XdtDeviceBridge" Height="820" Width="1200">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <Button Content="AIS-GDT-Datei auswählen" Width="220" Margin="0,0,8,0" Click="SelectAisFile_Click" />
            <TextBox x:Name="AisFilePathTextBox" IsReadOnly="True" MinWidth="900" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
            <Button Content="NIDEK-XML-Datei auswählen" Width="220" Margin="0,0,8,0" Click="SelectDeviceFile_Click" />
            <TextBox x:Name="DeviceFilePathTextBox" IsReadOnly="True" MinWidth="900" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,8">
            <Button Content="Verarbeiten" Width="150" Margin="0,0,8,0" Click="Process_Click" />
            <Button Content="Exportdatei schreiben" Width="180" Click="Export_Click" />
        </StackPanel>

        <GroupBox Header="Profile" Grid.Row="3" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AisProfileCountText" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Geräte:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="DeviceProfileCountText" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Export:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="0" Grid.Column="5" x:Name="ExportProfileCountText" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="0" Grid.Column="6" Text="Schnittstellen:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="0" Grid.Column="7" x:Name="InterfaceProfileCountText" Margin="0,0,12,0"/>
                <TextBlock Grid.Row="0" Grid.Column="8" Text="BaseFolder:" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="0" Grid.Column="9" x:Name="ProfileBaseFolderText" TextTrimming="CharacterEllipsis"/>
                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="10" Content="Templatepaket exportieren" Width="190" Margin="0,8,0,0" HorizontalAlignment="Left" Click="ExportTemplatePackage_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Patientendaten" Grid.Row="4" Margin="0,0,0,8">
            <UniformGrid Columns="2" Margin="8">
                <TextBlock Text="PatientNumber:" FontWeight="Bold"/><TextBlock x:Name="PatientNumberText"/>
                <TextBlock Text="LastName:" FontWeight="Bold"/><TextBlock x:Name="LastNameText"/>
                <TextBlock Text="FirstName:" FontWeight="Bold"/><TextBlock x:Name="FirstNameText"/>
                <TextBlock Text="BirthDate:" FontWeight="Bold"/><TextBlock x:Name="BirthDateText"/>
                <TextBlock Text="Street:" FontWeight="Bold"/><TextBlock x:Name="StreetText"/>
                <TextBlock Text="PostalCodeCity:" FontWeight="Bold"/><TextBlock x:Name="PostalCodeCityText"/>
            </UniformGrid>
        </GroupBox>

        <GroupBox Header="Messwerte" Grid.Row="5" Margin="0,0,0,8">
            <DataGrid x:Name="MeasurementsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SourcePath" Binding="{Binding SourcePath}" Width="*"/>
                    <DataGridTextColumn Header="Eye" Binding="{Binding Eye}" Width="80"/>
                    <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120"/>
                    <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="120"/>
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100"/>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Header="Exportvorschau" Grid.Row="6" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="PlannedFileNameText" FontWeight="Bold" Margin="8"/>
                <TextBox x:Name="ExportPreviewTextBox" Grid.Row="1" Margin="8" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Meldungen" Grid.Row="7">
            <TextBox x:Name="MessagesTextBox" Margin="8" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
        </GroupBox>
    </Grid>
</Window>
