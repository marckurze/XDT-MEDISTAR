<Window x:Class="XdtDeviceBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:XdtDeviceBridge.Core;assembly=XdtDeviceBridge.Core"
        xmlns:local="clr-namespace:XdtDeviceBridge.App"
        Title="XDTBox"
        Icon="Assets/App/XDTBox.ico"
        Height="900"
        Width="1200"
        MinHeight="800"
        MinWidth="1200"
        Background="{DynamicResource XdtBoxWindowBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/XdtBoxTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:DeviceImageSourceConverter x:Key="DeviceImageSourceConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="12" Style="{StaticResource XdtBoxRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource XdtBoxBrandHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="Assets/Branding/XDTBox_Logo_Schriftzug.png"
                       Style="{StaticResource XdtBoxLogoImageStyle}"
                       MaxWidth="360"/>
                <DockPanel Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           LastChildFill="False">
                    <TextBlock Text="Medizinische Geräte sicher verbinden"
                               DockPanel.Dock="Right"
                               Foreground="{StaticResource XdtBoxDarkTextBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
        <TabControl x:Name="MainTabControl">
            <TabItem Header="Verarbeitung">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8" MinHeight="700">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Aktive Schnittstellenprofile" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.Resources>
                                    <Style x:Key="MonitoringCardBorderStyle" TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#34D399"/>
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#F6FFF9" Offset="0"/>
                                                    <GradientStop Color="#E9F8EF" Offset="0.58"/>
                                                    <GradientStop Color="#F8FFFB" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="Padding" Value="10"/>
                                        <Setter Property="Margin" Value="0,0,10,10"/>
                                        <Setter Property="Width" Value="350"/>
                                        <Setter Property="MinHeight" Value="168"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="14"
                                                                  ShadowDepth="2"
                                                                  Direction="270"
                                                                  Color="#55745F"
                                                                  Opacity="0.18"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Active">
                                                <Setter Property="BorderBrush" Value="#22C55E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Waiting">
                                                <Setter Property="BorderBrush" Value="#34D399"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Success">
                                                <Setter Property="BorderBrush" Value="#16A34A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Error">
                                                <Setter Property="BorderBrush" Value="#22C55E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Blocked">
                                                <Setter Property="BorderBrush" Value="#22C55E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                                <Setter Property="Width" Value="{x:Static core:InterfaceProfileUiPolicy.PilotMonitoringCardWidth}"/>
                                                <Setter Property="MinHeight" Value="248"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="MonitoringInputBadgeStyle" TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#D6CDB9"/>
                                        <Setter Property="Background" Value="#FFFDF7"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="6"/>
                                        <Setter Property="Padding" Value="6"/>
                                        <Setter Property="Margin" Value="0,0,4,6"/>
                                        <Setter Property="MinWidth" Value="{x:Static core:InterfaceProfileUiPolicy.MonitoringInputBadgeMinWidth}"/>
                                        <Setter Property="MaxWidth" Value="{x:Static core:InterfaceProfileUiPolicy.MonitoringInputBadgeMaxWidth}"/>
                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="7"
                                                                  ShadowDepth="1"
                                                                  Direction="270"
                                                                  Color="#7B8A80"
                                                                  Opacity="0.18"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Active">
                                                <Setter Property="BorderBrush" Value="#7DD3FC"/>
                                                <Setter Property="Background" Value="#F0F9FF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Error">
                                                <Setter Property="BorderBrush" Value="#F97316"/>
                                                <Setter Property="Background" Value="#FFF7ED"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Waiting">
                                                <Setter Property="BorderBrush" Value="#E7D8B0"/>
                                                <Setter Property="Background" Value="#FFFDF4"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Success">
                                                <Setter Property="BorderBrush" Value="#22C55E"/>
                                                <Setter Property="Background" Value="#ECFDF3"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusClass}" Value="Blocked">
                                                <Setter Property="BorderBrush" Value="#EA580C"/>
                                                <Setter Property="Background" Value="#FFF7ED"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style x:Key="MonitoringSymbolButtonStyle" TargetType="Button">
                                        <Setter Property="Width" Value="30"/>
                                        <Setter Property="Height" Value="28"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="FontFamily" Value="Segoe UI Symbol, Segoe UI Emoji"/>
                                        <Setter Property="Foreground" Value="#14532D"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border x:Name="ButtonChrome"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                          Margin="{TemplateBinding Padding}"
                                                                          RecognizesAccessKey="True"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ButtonChrome" Property="Background" Value="#1A22C55E"/>
                                                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#6634D399"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="ButtonChrome" Property="Background" Value="#3322C55E"/>
                                                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#16A34A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Foreground" Value="#9CA3AF"/>
                                                            <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.55"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Grid.Resources>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="Diese Übersicht zeigt aktive Schnittstellen für die automatische Verarbeitung. XDTBox überwacht die konfigurierten Ordner, sobald die Überwachung läuft."
                                           Foreground="DimGray"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1"
                                           x:Name="ActiveInterfaceProfilesStatusText"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                                    <Button x:Name="StartPeriodicScanButton"
                                            Content="Überwachung starten"
                                            Width="170"
                                            Margin="0,0,8,8"
                                            Click="StartPeriodicScan_Click"/>
                                    <Button x:Name="StopPeriodicScanButton"
                                            Content="Überwachung stoppen"
                                            Width="170"
                                            IsEnabled="False"
                                            Margin="0,0,16,8"
                                            Click="StopPeriodicScan_Click"/>
                                    <TextBlock Text="Status:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock x:Name="PeriodicScanStatusText" Text="Gestoppt" MinWidth="80" Margin="0,3,16,8"/>
                                    <TextBlock Text="Intervall:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock x:Name="PeriodicScanIntervalText" Text="5 Sekunden" MinWidth="80" Margin="0,3,16,8"/>
                                    <TextBlock Text="Letzter Scan:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock x:Name="PeriodicScanLastRunText" Text="-" MinWidth="130" Margin="0,3,16,8"/>
                                    <TextBlock Text="Fertige Paare letzter Scan:" FontWeight="Bold" Margin="0,3,4,8"/>
                                    <TextBlock x:Name="PeriodicScanReadyPairsText" Text="0" MinWidth="40" Margin="0,3,0,8"/>
                                    <TextBlock Text="Gefundene passende Dateipaare werden automatisch verarbeitet, sobald die Überwachung läuft. Importdateien werden nur gemäß Schnittstellenprofil behandelt."
                                               Foreground="DimGray"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,8"/>
                                </WrapPanel>
                                <ItemsControl Grid.Row="3"
                                              x:Name="InterfaceMonitoringCardsItemsControl"
                                              Margin="0,0,0,4">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource MonitoringCardBorderStyle}">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,5">
                                                        <Button DockPanel.Dock="Right"
                                                                Style="{StaticResource MonitoringSymbolButtonStyle}"
                                                                Content="🗗"
                                                                Margin="8,0,0,0"
                                                                Click="DetachMonitoringCard_Click"
                                                                ToolTip="Fenster abdocken"
                                                                AutomationProperties.Name="Fenster abdocken"/>
                                                        <Button DockPanel.Dock="Right"
                                                                Style="{StaticResource MonitoringSymbolButtonStyle}"
                                                                Content="↺"
                                                                Margin="8,0,0,0"
                                                                Click="ResetMonitoringCard_Click"
                                                                ToolTip="Vorgang zurücksetzen"
                                                                AutomationProperties.Name="Vorgang zurücksetzen"/>
                                                        <StackPanel>
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{Binding InterfaceProfileName}"
                                                                       FontSize="11"
                                                                       FontWeight="Bold"
                                                                       Foreground="#18392A"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding InterfaceProfileName}"/>
                                                            <TextBlock Text="{Binding AisName, StringFormat=AIS: {0}}"
                                                                       FontSize="11"
                                                                       Foreground="#46685A"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DockPanel>

                                                    <Border CornerRadius="8"
                                                            BorderThickness="0"
                                                            Background="#0AF6FFF9"
                                                            Padding="4"
                                                            Margin="0,0,0,7">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid Height="150">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="190"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="54"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Setter Property="Grid.Column" Value="0"/>
                                                                        <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                                        <Setter Property="Grid.Row" Value="0"/>
                                                                        <Setter Property="Grid.RowSpan" Value="2"/>
                                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                                        <Setter Property="Margin" Value="0,0,8,0"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding UsesTextAboveImageLayout}" Value="True">
                                                                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                                                <Setter Property="Grid.RowSpan" Value="1"/>
                                                                                <Setter Property="VerticalAlignment" Value="Top"/>
                                                                                <Setter Property="Margin" Value="0,0,8,6"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>
                                                                <TextBlock Text="{Binding EffectiveDeviceTypeDisplay}"
                                                                           FontSize="18"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#102A1F"
                                                                           TextWrapping="Wrap"
                                                                           MaxHeight="50"
                                                                           ToolTip="{Binding DeviceType}"/>
                                                                <TextBlock Text="{Binding InterfaceProfileName}"
                                                                           FontSize="14"
                                                                           Foreground="#102A1F"
                                                                           TextWrapping="Wrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxHeight="58"
                                                                           ToolTip="{Binding InterfaceProfileName}"
                                                                           Margin="0,7,0,0"/>
                                                            </StackPanel>

                                                            <Grid>
                                                                <Grid.Style>
                                                                    <Style TargetType="Grid">
                                                                        <Setter Property="Grid.Column" Value="1"/>
                                                                        <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                                        <Setter Property="Grid.Row" Value="0"/>
                                                                        <Setter Property="Grid.RowSpan" Value="2"/>
                                                                        <Setter Property="Margin" Value="-8,-8,-4,-4"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding UsesTextAboveImageLayout}" Value="True">
                                                                                <Setter Property="Grid.Column" Value="0"/>
                                                                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                                                <Setter Property="Grid.Row" Value="1"/>
                                                                                <Setter Property="Grid.RowSpan" Value="1"/>
                                                                                <Setter Property="Margin" Value="0,-2,-4,-4"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <Border Background="#10FFFFFF"
                                                                        CornerRadius="8"/>
                                                                <Image Source="{Binding DeviceImagePath, Converter={StaticResource DeviceImageSourceConverter}}"
                                                                       Stretch="Uniform"
                                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasDeviceImage}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                                <TextBlock Text="Kein Gerätebild"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="#6B7280">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasDeviceImage}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>

                                                            <Grid Grid.Column="2"
                                                                  Grid.Row="0"
                                                                  Grid.RowSpan="2"
                                                                  Width="52"
                                                                  Height="52"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Loaded="MonitoringPilotStatusOrb_Loaded"
                                                                  Unloaded="MonitoringPilotStatusOrb_Unloaded"
                                                                  DataContextChanged="MonitoringPilotStatusOrb_DataContextChanged"
                                                                  ToolTip="{Binding CurrentStatus}">
                                                                <Ellipse Width="40"
                                                                         Height="40"
                                                                         Tag="StatusOrb"
                                                                         RenderTransformOrigin="0.5,0.5"
                                                                         Opacity="0.92">
                                                                    <Ellipse.RenderTransform>
                                                                        <ScaleTransform/>
                                                                    </Ellipse.RenderTransform>
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect BlurRadius="16"
                                                                                                      ShadowDepth="2"
                                                                                                      Direction="270"
                                                                                                      Color="#991B1B"
                                                                                                      Opacity="0.34"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Setter Property="Fill">
                                                                                <Setter.Value>
                                                                                    <RadialGradientBrush Center="0.34,0.28"
                                                                                                         GradientOrigin="0.22,0.18"
                                                                                                         RadiusX="0.72"
                                                                                                         RadiusY="0.72">
                                                                                        <GradientStop Color="#FEE2E2" Offset="0"/>
                                                                                        <GradientStop Color="#EF4444" Offset="0.42"/>
                                                                                        <GradientStop Color="#B91C1C" Offset="1"/>
                                                                                    </RadialGradientBrush>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding ShouldPulseStatusOrb}" Value="True">
                                                                                    <Setter Property="Effect">
                                                                                        <Setter.Value>
                                                                                            <DropShadowEffect BlurRadius="16"
                                                                                                              ShadowDepth="2"
                                                                                                              Direction="270"
                                                                                                              Color="#166534"
                                                                                                              Opacity="0.34"/>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Setter Property="Fill">
                                                                                        <Setter.Value>
                                                                                            <RadialGradientBrush Center="0.34,0.28"
                                                                                                                 GradientOrigin="0.22,0.18"
                                                                                                                 RadiusX="0.72"
                                                                                                                 RadiusY="0.72">
                                                                                                <GradientStop Color="#DCFCE7" Offset="0"/>
                                                                                                <GradientStop Color="#22C55E" Offset="0.42"/>
                                                                                                <GradientStop Color="#15803D" Offset="1"/>
                                                                                            </RadialGradientBrush>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <Ellipse Width="40"
                                                                         Height="40"
                                                                         Tag="StatusOrbFlash"
                                                                         Fill="#FFFFFFFF"
                                                                         Opacity="0"/>
                                                                <Ellipse Width="12"
                                                                         Height="8"
                                                                         Fill="#CCFFFFFF"
                                                                         HorizontalAlignment="Left"
                                                                         VerticalAlignment="Top"
                                                                         Margin="13,11,0,0"/>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>

                                                    <Border CornerRadius="6"
                                                            BorderThickness="1"
                                                            BorderBrush="#14532D"
                                                            Background="#082116"
                                                            Padding="6"
                                                            Margin="0,0,0,7">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid x:Name="MonitoringRadarSurface"
                                                              Height="54"
                                                              ClipToBounds="True"
                                                              Loaded="MonitoringRadar_Loaded"
                                                              Unloaded="MonitoringRadar_Unloaded"
                                                              DataContextChanged="MonitoringRadar_DataContextChanged"
                                                              ToolTip="{Binding ScanIntervalText, StringFormat=Radar-Puls: {0}}">
                                                            <Grid.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#08291D" Offset="0"/>
                                                                    <GradientStop Color="#0F3A2A" Offset="0.55"/>
                                                                    <GradientStop Color="#05130E" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Grid.Background>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="*"/>
                                                                </Grid.RowDefinitions>
                                                                <Border Grid.Row="0" BorderBrush="#1F6B46" BorderThickness="0,0,0,1" Opacity="0.55"/>
                                                                <Border Grid.Row="1" BorderBrush="#1F6B46" BorderThickness="0,0,0,1" Opacity="0.45"/>
                                                            </Grid>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" BorderBrush="#1F6B46" BorderThickness="0,0,1,0" Opacity="0.35"/>
                                                                <Border Grid.Column="1" BorderBrush="#1F6B46" BorderThickness="0,0,1,0" Opacity="0.45"/>
                                                                <Border Grid.Column="2" BorderBrush="#1F6B46" BorderThickness="0,0,1,0" Opacity="0.35"/>
                                                            </Grid>
                                                            <Rectangle Height="46"
                                                                       Width="17"
                                                                       RadiusX="3"
                                                                       RadiusY="3"
                                                                       HorizontalAlignment="Left"
                                                                       VerticalAlignment="Center"
                                                                       Tag="RadarScanBar"
                                                                       Opacity="0.58">
                                                                <Rectangle.RenderTransform>
                                                                    <TranslateTransform/>
                                                                </Rectangle.RenderTransform>
                                                                <Rectangle.Style>
                                                                    <Style TargetType="Rectangle">
                                                                        <Setter Property="Fill">
                                                                            <Setter.Value>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                    <GradientStop Color="#002417" Offset="0"/>
                                                                                    <GradientStop Color="#10B981" Offset="0.38"/>
                                                                                    <GradientStop Color="#BBF7D0" Offset="0.52"/>
                                                                                    <GradientStop Color="#10B981" Offset="0.66"/>
                                                                                    <GradientStop Color="#002417" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsScanAnimationActive}" Value="False">
                                                                                <Setter Property="Fill" Value="#6B7280"/>
                                                                                <Setter Property="Opacity" Value="0.45"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Rectangle.Style>
                                                            </Rectangle>
                                                            <Border BorderBrush="#5EEA92"
                                                                    BorderThickness="1"
                                                                    Opacity="0.32"/>
                                                            <TextBlock Text="{Binding ScanIntervalText, StringFormat=Scan {0}}"
                                                                       Foreground="#BBF7D0"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Right"
                                                                       VerticalAlignment="Bottom"
                                                                       Margin="0,0,6,4"/>
                                                        </Grid>
                                                    </Border>

                                                    <WrapPanel Margin="0,0,0,6">
                                                        <WrapPanel.Style>
                                                            <Style TargetType="WrapPanel">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </WrapPanel.Style>
                                                        <Button Content="−"
                                                                Style="{StaticResource MonitoringSymbolButtonStyle}"
                                                                Margin="0,0,4,4"
                                                                Click="DecreaseMonitoringScanInterval_Click"
                                                                ToolTip="Scanintervall um 1 Sekunde verringern"/>
                                                        <TextBlock Text="{Binding ScanIntervalText, StringFormat=Intervall: {0}}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,2,4,4"/>
                                                        <Button Content="+"
                                                                Style="{StaticResource MonitoringSymbolButtonStyle}"
                                                                Margin="0,0,12,4"
                                                                Click="IncreaseMonitoringScanInterval_Click"
                                                                ToolTip="Scanintervall um 1 Sekunde erhöhen"/>
                                                        <TextBlock Text="{Binding LastScanText, StringFormat=Letzter Scan: {0}}" Margin="0,0,12,4"/>
                                                        <TextBlock Text="{Binding AutomaticProcessingText, StringFormat=Automatik: {0}}" Margin="0,0,0,4"/>
                                                    </WrapPanel>

                                                    <WrapPanel Margin="0,0,0,6"
                                                               HorizontalAlignment="Left">
                                                        <WrapPanel.Style>
                                                            <Style TargetType="WrapPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UsesPilotDeviceVisual}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </WrapPanel.Style>
                                                        <Button Content="−"
                                                                Style="{StaticResource MonitoringSymbolButtonStyle}"
                                                                Margin="0,0,6,4"
                                                                Click="DecreaseMonitoringScanInterval_Click"
                                                                ToolTip="Scanintervall um 1 Sekunde verringern"/>
                                                        <TextBlock Text="{Binding ScanIntervalText, StringFormat=Intervall: {0}}"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,2,6,4"/>
                                                        <Button Content="+"
                                                                Style="{StaticResource MonitoringSymbolButtonStyle}"
                                                                Margin="0,0,0,4"
                                                                Click="IncreaseMonitoringScanInterval_Click"
                                                                ToolTip="Scanintervall um 1 Sekunde erhöhen"/>
                                                    </WrapPanel>

                                                    <TextBlock Text="Erwartete Eingänge" FontWeight="Bold" Margin="0,0,0,4"/>
                                                    <ItemsControl ItemsSource="{Binding ExpectedInputs}" Margin="0,0,0,6">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource MonitoringInputBadgeStyle}"
                                                                        ToolTip="{Binding Detail}">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontWeight="Bold"
                                                                                   TextWrapping="NoWrap"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   ToolTip="{Binding Name}"/>
                                                                        <TextBlock Text="{Binding Status}" Foreground="DimGray" TextWrapping="Wrap">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Status}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding DisplayDetail}"
                                                                                   Foreground="#4B5563"
                                                                                   FontSize="10"
                                                                                   TextWrapping="Wrap"
                                                                                   MaxHeight="34">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DisplayDetail}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Expander Header="Details"
                                                              IsExpanded="{Binding IsDetailsExpanded, Mode=OneWay}"
                                                              Expanded="MonitoringDetailsExpander_Expanded"
                                                              Collapsed="MonitoringDetailsExpander_Collapsed">
                                                        <StackPanel Margin="0,6,0,0">
                                                            <TextBlock Text="Statusdetails" FontWeight="Bold" Margin="0,0,0,4"/>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Schnittstelle" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding InterfaceProfileName}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Gerät" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DeviceName}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Exportprofil" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ExportProfileName}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Letzter Scan" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastScanText}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Automatik" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding AutomaticProcessingText}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Anhang" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding AttachmentConfigurationStatus}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Letzte Meldung" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding LastMessage}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Patient" FontWeight="Bold" Margin="0,0,8,0"/>
                                                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PatientDisplayText}" TextWrapping="Wrap"/>
                                                            </Grid>

                                                            <TextBlock Text="Datei- und Exportinformationen" FontWeight="Bold" Margin="0,2,0,4"/>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS-Datei" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AisFileName}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Gerätedatei" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DeviceFileName}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Anhang" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AttachmentFileName}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Export" FontWeight="Bold" Margin="0,0,8,3"/>
                                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ExportFileName}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Letzter Erfolg" FontWeight="Bold" Margin="0,0,8,0"/>
                                                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastSuccessfulExportText}" TextWrapping="Wrap"/>
                                                            </Grid>

                                                            <TextBlock Text="Ordnerinformationen" FontWeight="Bold" Margin="0,2,0,4"/>
                                                            <ItemsControl ItemsSource="{Binding FolderDetails}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="0,0,0,3">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="130"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" Margin="0,0,8,0"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </GroupBox>

                        <Expander Header="Monitoring-Ereignisse" Grid.Row="1" IsExpanded="False" Margin="0,0,0,8">
                            <Border Margin="0,8,0,0"
                                    Height="190"
                                    CornerRadius="8"
                                    BorderBrush="#22C55E"
                                    BorderThickness="1"
                                    Padding="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#071F16" Offset="0"/>
                                        <GradientStop Color="#0B2A1F" Offset="0.55"/>
                                        <GradientStop Color="#06120D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBox x:Name="MessagesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Foreground="#CFFFE2"
                                         CaretBrush="#CFFFE2"
                                         Background="#22000000"
                                         BorderBrush="#335EEA92"
                                         BorderThickness="1"
                                         Padding="8"/>
                            </Border>
                        </Expander>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Profile &amp; Templates">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Expander Header="Profilübersicht" IsExpanded="True" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AisProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Geräte:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="DeviceProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Export:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" x:Name="ExportProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="Schnittstellen:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="7" x:Name="InterfaceProfileCountText" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="BaseFolder:" FontWeight="Bold" Margin="0,0,4,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="7" x:Name="ProfileBaseFolderText" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Expander>

                        <Expander Header="Templatepakete, neue Profile und RS232-Test" IsExpanded="True" Grid.Row="1" Margin="0,0,0,8">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Templatepaket-Export"
                                           FontWeight="Bold"
                                           Margin="0,0,0,4"/>
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="Paketbasis:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <ComboBox x:Name="TemplatePackageExportInterfaceProfileComboBox"
                                              MinWidth="360"
                                              DisplayMemberPath="Metadata.Name"
                                              SelectionChanged="TemplatePackageExportInterfaceProfileComboBox_SelectionChanged"/>
                                </DockPanel>
                                <TextBlock x:Name="TemplatePackageExportSelectionHintText"
                                           Text="Bitte ein Schnittstellenprofil als Paketbasis wählen."
                                           Foreground="DimGray"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <WrapPanel Grid.Row="1">
                                <Button Content="Templatepaket exportieren" Width="190" Margin="0,0,8,8" Click="ExportTemplatePackage_Click"/>
                                <Button x:Name="ImportTemplatePackageButton" Content="Templatepaket importieren" Width="190" Margin="0,0,16,8" Click="ImportTemplatePackage_Click"/>
                                <Button Content="Neues AIS anlegen" Width="160" Margin="0,0,8,8" Click="CreateNewAisProfile_Click"/>
                                <Button Content="Neues Gerät anlegen" Width="170" Margin="0,0,8,8" Click="CreateNewDeviceProfile_Click"/>
                                <Button Content="Gerät laden" Width="120" Margin="0,0,8,8" Click="LoadDeviceProfile_Click"/>
                                <Button Content="Neues Exportprofil anlegen" Width="200" Margin="0,0,8,8" Click="CreateNewExportProfile_Click"/>
                            </WrapPanel>
                            <GroupBox Grid.Row="2"
                                      Header="RS232 / COM-Port testen"
                                      Margin="0,8,0,0">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="120"/>
                                        <RowDefinition Height="160"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="COM-Port:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SerialTestPortComboBox" IsEditable="True" Margin="0,0,8,8" ToolTip="COM-Port, z. B. COM1 oder COM3."/>
                                    <Button Grid.Row="0" Grid.Column="2" x:Name="RefreshSerialTestPortsButton" Content="Aktualisieren" Width="110" Margin="0,0,16,8" Click="RefreshSerialTestPorts_Click"/>

                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Baudrate:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="SerialTestBaudRateTextBox" Text="9600" Width="120" HorizontalAlignment="Left" Margin="0,0,8,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Datenbits:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="SerialTestDataBitsTextBox" Text="8" Width="120" HorizontalAlignment="Left" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Stoppbits:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <ComboBox Grid.Row="1" Grid.Column="4" x:Name="SerialTestStopBitsComboBox" SelectedValuePath="Tag" SelectedValue="One" Width="160" HorizontalAlignment="Left" Margin="0,0,8,8">
                                        <ComboBoxItem Content="1" Tag="One"/>
                                        <ComboBoxItem Content="1,5" Tag="OnePointFive"/>
                                        <ComboBoxItem Content="2" Tag="Two"/>
                                    </ComboBox>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Flusskontrolle:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="SerialTestHandshakeComboBox" SelectedValuePath="Tag" SelectedValue="None" Width="170" HorizontalAlignment="Left" Margin="0,0,8,8">
                                        <ComboBoxItem Content="Keine" Tag="None"/>
                                        <ComboBoxItem Content="RTS/CTS" Tag="RequestToSend"/>
                                        <ComboBoxItem Content="XON/XOFF" Tag="XOnXOff"/>
                                        <ComboBoxItem Content="RTS/CTS + XON/XOFF" Tag="RequestToSendXOnXOff"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Parität:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <ComboBox Grid.Row="2" Grid.Column="4" x:Name="SerialTestParityComboBox" SelectedValuePath="Tag" SelectedValue="None" Width="160" HorizontalAlignment="Left" Margin="0,0,8,8">
                                        <ComboBoxItem Content="Keine" Tag="None"/>
                                        <ComboBoxItem Content="Odd" Tag="Odd"/>
                                        <ComboBoxItem Content="Even" Tag="Even"/>
                                        <ComboBoxItem Content="Mark" Tag="Mark"/>
                                        <ComboBoxItem Content="Space" Tag="Space"/>
                                    </ComboBox>
                                    <StackPanel Grid.Row="2" Grid.Column="5" Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox x:Name="SerialTestDtrCheckBox" Content="DTR" Margin="0,0,12,0" ToolTip="DTR-Leitung beim Öffnen des COM-Ports aktivieren."/>
                                        <CheckBox x:Name="SerialTestRtsCheckBox" Content="RTS" IsChecked="True" ToolTip="RTS-Leitung beim Öffnen des COM-Ports aktivieren."/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Protokoll:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="SerialTestProtocolComboBox" SelectedValuePath="Tag" SelectedValue="Raw" Width="170" HorizontalAlignment="Left" Margin="0,0,8,8">
                                        <ComboBoxItem Content="Raw" Tag="Raw"/>
                                        <ComboBoxItem Content="NIDEK RS232" Tag="NidekRs232"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="Modus:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <ComboBox Grid.Row="3" Grid.Column="4" x:Name="SerialTestNidekModeComboBox" SelectedValuePath="Tag" SelectedValue="Unknown" Width="190" HorizontalAlignment="Left" Margin="0,0,8,8">
                                        <ComboBoxItem Content="Listen only" Tag="Unknown"/>
                                        <ComboBoxItem Content="NCP10" Tag="Ncp10"/>
                                        <ComboBoxItem Content="NIDEK RS-SD vorbereitet" Tag="Nidek"/>
                                    </ComboBox>
                                    <Button Grid.Row="3" Grid.Column="5" x:Name="ParseSerialTestRawButton" Content="Rohdaten auswerten" Width="150" HorizontalAlignment="Left" Margin="0,0,0,8" Click="ParseSerialTestRaw_Click"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Dauer:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,8">
                                        <TextBox x:Name="SerialTestDurationSecondsTextBox" Text="10" Width="80"/>
                                        <TextBlock Text=" Sekunden" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Row="4" Grid.Column="2" x:Name="SerialTestStartButton" Content="Start" Width="110" Margin="0,0,8,8" Click="StartSerialTestListen_Click"/>
                                    <Button Grid.Row="4" Grid.Column="3" x:Name="SerialTestStopButton" Content="Stop" Width="110" Margin="0,0,8,8" Click="StopSerialTestListen_Click" IsEnabled="False"/>
                                    <TextBlock Grid.Row="4" Grid.Column="4" x:Name="SerialTestBytesTextBlock" Text="0 Bytes" VerticalAlignment="Center" Margin="0,0,8,8"/>

                                    <StackPanel Grid.Row="4" Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                                        <TextBox x:Name="SerialTestCommandTextBox" MinWidth="220" HorizontalAlignment="Stretch" ToolTip="Optionaler Sendetext für bidirektionale RS232-Tests."/>
                                        <Button x:Name="SerialTestSendButton" Content="Senden" Width="90" Margin="8,0,0,0" Click="SendSerialTestCommand_Click"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Rohtext:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="5" x:Name="SerialTestRawTextBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" ToolTip="Empfangene oder eingefügte Rohdaten. Für NIDEK-RS232 können Steuerzeichen auch über Hex ausgewertet werden."/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Hex:" FontWeight="Bold" Margin="0,0,8,8"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="5" x:Name="SerialTestHexTextBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8" ToolTip="Empfangener oder eingefügter Hexdump, z. B. 01 44 4C 4D 02 ..."/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="NIDEK:" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="5" x:Name="SerialTestNidekAnalysisTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                                    <TextBlock Grid.Row="0" Grid.Column="5"
                                               x:Name="SerialTestStatusTextBlock"
                                               Foreground="DimGray"
                                               Text="Kein Mitschnitt gestartet."
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Grid.Row="3"
                                      Header="Profile umbenennen"
                                      Margin="0,8,0,0">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="Umbenannt wird nur der sichtbare Name von UserDefined-Profilen. Technische IDs, Verknüpfungen und Einstellungen bleiben unverändert."
                                               Foreground="DimGray"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>
                                    <WrapPanel Grid.Row="1">
                                        <TextBlock Text="AIS:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,8"/>
                                        <ComboBox x:Name="AisProfileRenameComboBox"
