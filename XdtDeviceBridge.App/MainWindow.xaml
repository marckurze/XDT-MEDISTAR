<Window x:Class="XdtDeviceBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XdtDeviceBridge"
        Height="900"
        Width="1200"
        MinHeight="800"
        MinWidth="1200">
    <Grid Margin="12">
        <TabControl>
            <TabItem Header="Verarbeitung">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8" MinHeight="700">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="3*"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="AIS-GDT-Datei auswählen" Margin="0,0,8,0" Click="SelectAisFile_Click" />
                            <TextBox Grid.Column="1" x:Name="AisFilePathTextBox" IsReadOnly="True" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="NIDEK-XML-Datei auswählen" Margin="0,0,8,0" Click="SelectDeviceFile_Click" />
                            <TextBox Grid.Column="1" x:Name="DeviceFilePathTextBox" IsReadOnly="True" />
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Verarbeiten" Width="150" Margin="0,0,8,0" Click="Process_Click" />
                            <Button Content="Exportdatei schreiben" Width="180" Click="Export_Click" />
                        </StackPanel>

                        <GroupBox Header="Patientendaten" Grid.Row="3" Margin="0,0,0,8">
                            <UniformGrid Columns="4" Margin="8">
                                <TextBlock Text="PatientNumber:" FontWeight="Bold"/>
                                <TextBlock x:Name="PatientNumberText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="LastName:" FontWeight="Bold"/>
                                <TextBlock x:Name="LastNameText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="FirstName:" FontWeight="Bold"/>
                                <TextBlock x:Name="FirstNameText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="BirthDate:" FontWeight="Bold"/>
                                <TextBlock x:Name="BirthDateText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Street:" FontWeight="Bold"/>
                                <TextBlock x:Name="StreetText" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="PostalCodeCity:" FontWeight="Bold"/>
                                <TextBlock x:Name="PostalCodeCityText" TextTrimming="CharacterEllipsis"/>
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Header="Messwerte" Grid.Row="4" Margin="0,0,0,0">
                            <DataGrid x:Name="MeasurementsGrid" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="SourcePath" Binding="{Binding SourcePath}" Width="*"/>
                                    <DataGridTextColumn Header="Eye" Binding="{Binding Eye}" Width="80"/>
                                    <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120"/>
                                    <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="140"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100"/>
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GridSplitter Grid.Row="5"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <GroupBox Header="Exportvorschau" Grid.Row="6" Margin="0,0,0,0">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="PlannedFileNameText" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBox x:Name="ExportPreviewTextBox"
                                         Grid.Row="1"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap"
                                         MinHeight="180"/>
                            </Grid>
                        </GroupBox>

                        <GridSplitter Grid.Row="7"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <GroupBox Header="Meldungen" Grid.Row="8">
                            <TextBox x:Name="MessagesTextBox"
                                     Margin="8"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     MinHeight="120"/>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Profile &amp; Templates">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Profilübersicht" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AisProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Geräte:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="DeviceProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Export:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" x:Name="ExportProfileCountText" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="Schnittstellen:" FontWeight="Bold" Margin="0,0,4,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="7" x:Name="InterfaceProfileCountText" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="BaseFolder:" FontWeight="Bold" Margin="0,0,4,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="7" x:Name="ProfileBaseFolderText" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Templatepaket exportieren" Width="190" Margin="0,0,8,0" Click="ExportTemplatePackage_Click"/>
                            <Button Content="Templatepaket importieren" Width="190" Click="ImportTemplatePackage_Click"/>
                        </StackPanel>

                        <GroupBox Header="Profilnamen" Grid.Row="2" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="150"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Geräte" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Exportprofile" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="Schnittstellen" FontWeight="Bold" Margin="0,0,0,4"/>

                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         x:Name="AisProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="2"
                                         x:Name="DeviceProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="4"
                                         x:Name="ExportProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="6"
                                         x:Name="InterfaceProfileNamesTextBox"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Exportregeln" Grid.Row="3" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Exportprofil:"
                                           FontWeight="Bold"
                                           Margin="0,0,8,8"
                                           ToolTip="Legt fest, wie AIS-Daten und Gerätewerte in eine Rückgabedatei geschrieben werden."/>
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          x:Name="ExportProfileComboBox"
                                          DisplayMemberPath="Metadata.Name"
                                          MinWidth="360"
                                          Margin="0,0,0,8"
                                          ToolTip="Legt fest, wie AIS-Daten und Gerätewerte in eine Rückgabedatei geschrieben werden."
                                          SelectionChanged="ExportProfileComboBox_SelectionChanged"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           x:Name="ExportRulesStatusText"
                                           Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="2"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          x:Name="ExportRulesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          MinHeight="260"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          SelectionChanged="ExportRulesGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding SortOrder}" Width="80">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="SortOrder" ToolTip="Reihenfolge der Ausgabezeilen in der erzeugten XDT-Datei."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding TargetFieldCode}" Width="120">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="TargetFieldCode" ToolTip="XDT/GDT-Feldkennung, in die der Wert geschrieben wird, z. B. 6228 für Ergebnistext."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding TargetName}" Width="160">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="TargetName" ToolTip="Interner Anzeigename der Exportregel."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding RuleType}" Width="110">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="RuleType" ToolTip="Art der Regel: fester Wert, AIS-Feld, Gerätewert oder zusammengesetztes Template."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding SourcePath}" Width="220">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="SourcePath" ToolTip="Quelle des Werts, z. B. AIS.PatientNumber oder Device.R/AR/ARMedian/Sphere."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Binding="{Binding OutputTemplate}" Width="420">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="OutputTemplate" ToolTip="Ausgabeformat. Platzhalter werden in geschweiften Klammern geschrieben, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                        <DataGridCheckBoxColumn Binding="{Binding IsEnabled}" Width="90">
                                            <DataGridCheckBoxColumn.Header>
                                                <TextBlock Text="IsEnabled" ToolTip="Legt fest, ob diese Regel beim Export berücksichtigt wird."/>
                                            </DataGridCheckBoxColumn.Header>
                                        </DataGridCheckBoxColumn>
                                        <DataGridTextColumn Binding="{Binding Description}" Width="260">
                                            <DataGridTextColumn.Header>
                                                <TextBlock Text="Description" ToolTip="Beschreibung oder Hinweis zur Regel."/>
                                            </DataGridTextColumn.Header>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Exportregel-Arbeitsbereich" Grid.Row="4" Margin="0,0,0,8">
                            <Grid Margin="8" MinHeight="720">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="170"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="260"/>
                                    </Grid.RowDefinitions>

                                    <GroupBox Header="Exportregel-Entwurf" Grid.Row="0" Margin="0,0,0,0">
                                        <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="4"
                                           Text="Entwurfsmodus: Änderungen werden noch nicht gespeichert."
                                           FontWeight="Bold"
                                           Foreground="DarkRed"
                                           Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TargetFieldCode:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="XDT/GDT-Feldkennung, in die der Wert geschrieben wird, z. B. 6228 für Ergebnistext."/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="DraftTargetFieldCodeTextBox" Margin="0,0,16,8" ToolTip="XDT/GDT-Feldkennung, in die der Wert geschrieben wird, z. B. 6228 für Ergebnistext."/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="TargetName:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Interner Anzeigename der Exportregel."/>
                                <TextBox Grid.Row="1" Grid.Column="3" x:Name="DraftTargetNameTextBox" Margin="0,0,0,8" ToolTip="Interner Anzeigename der Exportregel."/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="RuleType:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Art der Regel: fester Wert, AIS-Feld, Gerätewert oder zusammengesetztes Template."/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DraftRuleTypeComboBox" Margin="0,0,16,8" ToolTip="Art der Regel: fester Wert, AIS-Feld, Gerätewert oder zusammengesetztes Template."/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="SortOrder:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Reihenfolge der Ausgabezeilen in der erzeugten XDT-Datei."/>
                                <TextBox Grid.Row="2" Grid.Column="3" x:Name="DraftSortOrderTextBox" Margin="0,0,0,8" ToolTip="Reihenfolge der Ausgabezeilen in der erzeugten XDT-Datei."/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="SourcePath:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Quelle des Werts, z. B. AIS.PatientNumber oder Device.R/AR/ARMedian/Sphere."/>
                                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" x:Name="DraftSourcePathTextBox" Margin="0,0,0,8" ToolTip="Quelle des Werts, z. B. AIS.PatientNumber oder Device.R/AR/ARMedian/Sphere."/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="OutputTemplate:" FontWeight="Bold" Margin="0,0,8,8" ToolTip="Ausgabeformat. Platzhalter werden in geschweiften Klammern geschrieben, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}."/>
                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         x:Name="DraftOutputTemplateTextBox"
                                         MinHeight="80"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                          ToolTip="Ausgabeformat. Platzhalter werden in geschweiften Klammern geschrieben, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}."
                                         TextChanged="DraftOutputTemplateTextBox_TextChanged"
                                         Margin="0,0,0,8"/>
                                <CheckBox Grid.Row="5" Grid.Column="1" x:Name="DraftIsEnabledCheckBox" Content="IsEnabled" VerticalAlignment="Center" Margin="0,0,16,0" ToolTip="Legt fest, ob diese Regel beim Export berücksichtigt wird."/>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="Description:" FontWeight="Bold" Margin="0,0,8,0" ToolTip="Beschreibung oder Hinweis zur Regel."/>
                                <DockPanel Grid.Row="5" Grid.Column="3">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button Content="Entwurfsvorschau aktualisieren" Width="210" Margin="0,0,8,0" Click="UpdateDraftPreview_Click"/>
                                        <Button Content="Entwurf zurücksetzen" Width="160" Click="ResetDraft_Click"/>
                                    </StackPanel>
                                    <TextBox x:Name="DraftDescriptionTextBox" ToolTip="Beschreibung oder Hinweis zur Regel."/>
                                </DockPanel>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Regelvorschau" Grid.Row="2" Margin="0,0,0,0">
                                        <TextBox x:Name="ExportRulePreviewTextBox"
                                                 Margin="8"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </GroupBox>

                                    <GridSplitter Grid.Row="3"
                                                  Height="6"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  ResizeDirection="Rows"
                                                  ShowsPreview="True"/>

                                    <GroupBox Header="Gesamtexport-Vorschau" Grid.Row="4" Margin="0,0,0,0">
                                        <TextBox x:Name="FullExportPreviewTextBox"
                                                 Margin="8"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 FontFamily="Consolas"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </GroupBox>
                                </Grid>

                                <GridSplitter Grid.Column="1"
                                              Width="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Stretch"
                                              ResizeDirection="Columns"
                                              ShowsPreview="True"/>

                                <GroupBox Header="Verfügbare Platzhalter"
                                          Grid.Column="2"
                                          Margin="8,0,0,0"
                                          ToolTip="Diese Werte können in OutputTemplates verwendet werden. Platzhalter müssen mit geschweiften Klammern geschrieben werden.">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8">
                                            Platzhalter müssen mit geschweiften Klammern geschrieben werden, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}. Runde Klammern wie (Device.Date) werden nicht ersetzt.
                                            Über die Checkbox "Verwenden" kann ein Platzhalter in den aktuellen Entwurf eingefügt oder daraus entfernt werden. Der Ergebnistext bleibt weiterhin frei editierbar.
                                        </TextBlock>
                                        <TextBlock Grid.Row="1" Text="AIS-Platzhalter" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <DataGrid Grid.Row="2"
                                                  x:Name="AisPlaceholdersGrid"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasValue}" Value="True">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Platzhalter" Binding="{Binding Placeholder}" Width="190" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Name Messwert" Binding="{Binding DisplayName}" Width="160" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Ausgelesener Wert" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                                                <DataGridTemplateColumn Header="Verwenden" Width="85">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsUsed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalAlignment="Center"
                                                                      Checked="PlaceholderUseCheckBox_Changed"
                                                                      Unchecked="PlaceholderUseCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Grid.Row="3" x:Name="DevicePlaceholdersStatusText" Text="Device-Platzhalter" FontWeight="Bold" Margin="0,8,0,4"/>
                                        <DataGrid Grid.Row="4"
                                                  x:Name="DevicePlaceholdersGrid"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasValue}" Value="True">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Platzhalter" Binding="{Binding Placeholder}" Width="230" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Name Messwert" Binding="{Binding DisplayName}" Width="190" IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Ausgelesener Wert" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                                                <DataGridTemplateColumn Header="Verwenden" Width="85">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsUsed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalAlignment="Center"
                                                                      Checked="PlaceholderUseCheckBox_Changed"
                                                                      Unchecked="PlaceholderUseCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </GroupBox>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Profil- und Template-Meldungen" Grid.Row="7">
                            <TextBox x:Name="ProfileMessagesTextBox"
                                     Margin="8"
                                     MinHeight="160"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Lizenz">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Lizenzstatus" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Installation-ID:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="LicenseInstallationIdText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Computername:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LicenseMachineNameText" TextTrimming="CharacterEllipsis" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Benutzername:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="LicenseUserNameText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Terminalserver:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LicenseTerminalServerText" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Lizenzstatus:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="LicenseStatusText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Aktive Geräte:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LicenseActiveDeviceCountText" Margin="0,0,16,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Lizenzierte Geräte:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" x:Name="LicenseLicensedDeviceCountText"/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Lizenzanfrage exportieren" Width="190" Margin="0,0,8,0" Click="ExportLicenseRequest_Click"/>
                            <Button Content="Lizenzdatei importieren" Width="190" Click="ImportLicenseFile_Click"/>
                        </StackPanel>

                        <GroupBox Header="Lizenzmeldungen" Grid.Row="2">
                            <TextBox x:Name="LicenseMessagesTextBox"
                                     Margin="8"
                                     MinHeight="280"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
