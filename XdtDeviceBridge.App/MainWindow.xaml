                                                     Content="Ordner anlegen"
                                                     Width="120"
                                                     Margin="0,0,12,6"
                                                     Click="CreateInterfaceAttachmentFolders_Click"
                                                     ToolTip="Legt die aktuell eingetragenen XDT-Anhang-Ordner an. Vorhandene Ordner gelten als OK."/>
                                             <TextBlock x:Name="InterfaceAttachmentFolderSetupStatusTextBlock"
                                                        VerticalAlignment="Center"
                                                        Foreground="DimGray"
                                                        TextWrapping="Wrap"/>
                                         </WrapPanel>
                                     </Grid>
                                 </Expander>

                                <Expander Header="Ordnerbereinigung" IsExpanded="True" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <StackPanel Margin="8">
                                        <TextBlock Text="Ordnerbereinigung ist gefährlich. Es werden später nur explizit konfigurierte Arbeitsordner bereinigt. Root-, System- und Benutzerprofilordner sind nicht erlaubt. In diesem Schritt wird nur konfiguriert, nicht gelöscht."
                                                   Foreground="DarkRed"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <WrapPanel>
                                            <CheckBox x:Name="InterfaceClearAisImportFolderCheckBox"
                                                      Content="Bereits verarbeitete AIS-Dateien aus Importordner entfernen"
                                                      Margin="0,0,16,8"
                                                      ToolTip="Entfernen bedeutet: Dateien werden sicher ins Archiv verschoben, wenn sie bereits verarbeitet oder als Duplikat erkannt wurden. Es werden keine unbekannten neuen Dateien gelöscht."/>
                                            <CheckBox x:Name="InterfaceClearDeviceImportFolderCheckBox"
                                                      Content="Bereits verarbeitete Gerätedateien aus Importordner entfernen"
                                                      Margin="0,0,16,8"
                                                      ToolTip="Entfernen bedeutet: Dateien werden sicher ins Archiv verschoben, wenn sie bereits verarbeitet oder als Duplikat erkannt wurden. Es werden keine unbekannten neuen Dateien gelöscht."/>
                                            <CheckBox x:Name="InterfaceArchiveProcessedFilesCheckBox" Content="verarbeitete Dateien archivieren" Margin="0,0,16,8"/>
                                            <CheckBox x:Name="InterfaceMoveFailedFilesToErrorFolderCheckBox" Content="fehlerhafte Dateien in Fehlerordner verschieben" Margin="0,0,16,8"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Expander>

                                <Expander Header="Archivierung" IsExpanded="True" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Archivierungsmodus:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <ComboBox Grid.Row="0"
                                                  Grid.Column="1"
                                                  x:Name="InterfaceArchiveModeComboBox"
                                                  SelectedValuePath="Tag"
                                                  SelectedValue="Copy"
                                                  Width="220"
                                                  HorizontalAlignment="Left"
                                                  Margin="0,0,0,8"
                                                  ToolTip="Beim Modus 'Verschieben' werden verarbeitete Importdateien nach erfolgreicher Verarbeitung aus den Importordnern entfernt und ins Archiv verschoben. Dadurch wird eine erneute Verarbeitung derselben Dateien vermieden.">
                                            <ComboBoxItem Content="Kopieren" Tag="Copy"/>
                                            <ComboBoxItem Content="Verschieben" Tag="Move"/>
                                        </ComboBox>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Archiv löschen nach Tagen:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 x:Name="InterfaceArchiveRetentionDaysTextBox"
                                                 Width="120"
                                                 HorizontalAlignment="Left"
                                                 Margin="0,0,0,8"
                                                 ToolTip="Leer oder 0 bedeutet: keine automatische Löschung. Positive Zahlen konfigurieren die Aufbewahrungsfrist in Tagen."/>

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Text="Automatische Löschung betrifft nur den Archivordner und wird erst nach Ablauf der konfigurierten Aufbewahrungsfrist vorgesehen. Import-, Export- und Fehlerordner werden dadurch nicht bereinigt."
                                                   Foreground="DarkOrange"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </Expander>

                                <Expander Header="Prüfung vor Aktivierung" IsExpanded="True" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="Read-only Vorschau für den späteren Aktivierungsassistenten. Diese Prüfung aktiviert nichts, speichert nichts und startet keine Verarbeitung."
                                                   Foreground="DimGray"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <Grid Grid.Row="1" Margin="0,0,0,10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock x:Name="InterfaceActivationPreviewStatusText"
                                                       Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="Status: -"
                                                       FontWeight="Bold"
                                                       Margin="0,0,18,8"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="InterfaceActivationPreviewCanActivateText"
                                                       Grid.Row="0"
                                                       Grid.Column="1"
                                                       Text="Aktivierbar: -"
                                                       FontWeight="Bold"
                                                       Margin="0,0,18,8"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="InterfaceActivationPreviewCountsText"
                                                       Grid.Row="0"
                                                       Grid.Column="2"
                                                       Text="Blocker: 0 | Warnungen: 0 | Hinweise: 0"
                                                       Margin="0,0,0,8"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Grid.Row="1"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="3"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Left">
                                                <Button Content="Prüfung aktualisieren"
                                                        Width="180"
                                                        Margin="0,0,8,0"
                                                        Click="RefreshInterfaceActivationPreview_Click"/>
                                                <Button Content="Aktivierung vorbereiten"
                                                        Width="190"
                                                        Click="PrepareInterfaceActivationPreview_Click"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="2" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <GroupBox Header="Ordnerprüfung" Grid.Column="0" Margin="0,0,6,0">
                                                <DataGrid x:Name="InterfaceActivationPreviewFolderChecksGrid"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          HeadersVisibility="Column"
                                                          MinHeight="130"
                                                          MaxHeight="210"
                                                          Margin="8">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Ordner" Binding="{Binding Label}" Width="150"/>
                                                        <DataGridTextColumn Header="Pfad" Binding="{Binding Path}" Width="*"/>
                                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                                        <DataGridTextColumn Header="Erreichbar" Binding="{Binding Reachability}" Width="95"/>
                                                        <DataGridTextColumn Header="Hinweis" Binding="{Binding Message}" Width="*"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </GroupBox>

                                            <GroupBox Header="XDT-Anhang-Konfiguration" Grid.Column="1" Margin="6,0,0,0">
                                                <DataGrid x:Name="InterfaceActivationPreviewAttachmentChecksGrid"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          HeadersVisibility="Column"
                                                          MinHeight="130"
                                                          MaxHeight="210"
                                                          Margin="8">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Einstellung" Binding="{Binding Label}" Width="170"/>
                                                        <DataGridTextColumn Header="Wert" Binding="{Binding Value}" Width="*"/>
                                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                                        <DataGridTextColumn Header="Hinweis" Binding="{Binding Message}" Width="*"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </GroupBox>
                                        </Grid>

                                        <Grid Grid.Row="3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       x:Name="InterfaceActivationPreviewHintText"
                                                       Text="Bitte wählen Sie ein Schnittstellenprofil aus, um die Aktivierungsprüfung anzuzeigen."
                                                       TextWrapping="Wrap"
                                                       Foreground="DimGray"
                                                       Margin="0,0,0,6"/>
                                            <Expander Grid.Row="1" Header="Alle Prüfpunkte" IsExpanded="True">
                                                <DataGrid x:Name="InterfaceActivationPreviewChecksGrid"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          SelectionMode="Single"
                                                          HeadersVisibility="Column"
                                                          MinHeight="120"
                                                          MaxHeight="220">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Schweregrad" Binding="{Binding Severity}" Width="100"/>
                                                        <DataGridTextColumn Header="Bereich" Binding="{Binding Area}" Width="150"/>
                                                        <DataGridTextColumn Header="Prüfung" Binding="{Binding Message}" Width="*"/>
                                                        <DataGridTextColumn Header="Details" Binding="{Binding Detail}" Width="*"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Expander>
                                        </Grid>
                                    </Grid>
                                </Expander>
                             </Grid>
                         </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Sicherung/Umzug">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Sicherung erstellen" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="Erstellt eine vollständige XDTBox-Konfigurationssicherung mit Profilen, lokalen Gerätebildern, Lizenz-Kundendaten und optional importierter Lizenzdatei. Es werden keine Patientendaten oder Messdateien gesichert."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Zielpfad:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" x:Name="BackupTargetPathTextBox" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="Auswählen" Width="110" Click="SelectBackupTarget_Click"/>
                                </Grid>
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Button Content="Sicherung erstellen" Width="160" Margin="0,0,8,0" Click="CreateBackup_Click"/>
                                    <TextBlock x:Name="BackupCreateStatusText"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource XdtBoxMutedTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Sicherung wiederherstellen" Grid.Row="1" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="Wiederherstellung ersetzt lokale XDTBox-Konfigurationen. Bitte stellen Sie sicher, dass keine Verarbeitung läuft."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Sicherungsdatei:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" x:Name="BackupRestorePathTextBox" IsReadOnly="True" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="Sicherung auswählen" Width="150" Click="SelectBackupRestoreFile_Click"/>
                                </Grid>
                                <Border Grid.Row="2"
                                        BorderBrush="{StaticResource XdtBoxBorderBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource XdtBoxPanelBackgroundBrush}"
                                        Padding="8"
                                        Margin="0,0,0,8">
                                    <TextBlock x:Name="BackupManifestTextBlock"
                                               Text="Keine Sicherung ausgewählt."
                                               TextWrapping="Wrap"/>
                                </Border>
                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                    <Button Content="Wiederherstellen" Width="150" Margin="0,0,8,0" Click="RestoreBackup_Click"/>
                                    <TextBlock x:Name="BackupRestoreStatusText"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource XdtBoxMutedTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <Border Grid.Row="2"
                                BorderBrush="#E0A126"
                                BorderThickness="1"
                                Background="#FFF4D6"
                                CornerRadius="4"
                                Padding="10">
                            <StackPanel>
                                <TextBlock Text="Hardwareumzug"
                                           FontWeight="Bold"
                                           Foreground="#5A3A00"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Bei Hardwaretausch bitte neue Lizenz anfordern. Karenzzeit 7 Tage ab Umzug der Hardware."
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="#5A3A00"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Eine wiederhergestellte Lizenz kann auf neuer Hardware ungültig sein. Erzeugen Sie nach dem Umzug eine neue Lizenzanforderung."
                                           TextWrapping="Wrap"
                                           Foreground="#5A3A00"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Lizenz">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Lizenzstatus" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Installation-ID:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="LicenseInstallationIdText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Computername:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LicenseMachineNameText" TextTrimming="CharacterEllipsis" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Benutzername:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="LicenseUserNameText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Terminalserver:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LicenseTerminalServerText" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Lizenzstatus:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="LicenseStatusText" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Aktive Geräte:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LicenseActiveDeviceCountText" Margin="0,0,16,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Lizenzierte Geräte:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="3" x:Name="LicenseLicensedDeviceCountText"/>
                            </Grid>
                        </GroupBox>

                        <Border Grid.Row="1"
                                BorderBrush="#E0A126"
                                BorderThickness="1"
                                Background="#FFF4D6"
                                CornerRadius="4"
                                Padding="10"
                                Margin="0,0,0,8">
                            <TextBlock Text="Achtung: Bei Hardwaretausch bitte neue Lizenz anfordern, Karenzzeit 7 Tage ab Umzug der Hardware."
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Foreground="#5A3A00"/>
                        </Border>

                        <GroupBox Header="Kundendaten für Lizenzanforderung" Grid.Row="2" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Praxis-/Firmenname:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="LicenseCustomerNameTextBox" Margin="0,0,0,6"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Straße / Hausnummer:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="LicenseCustomerStreetTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="PLZ / Ort:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBox x:Name="LicenseCustomerPostalCodeTextBox" Width="100" Margin="0,0,8,0"/>
                                    <TextBox x:Name="LicenseCustomerCityTextBox" MinWidth="220"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Telefon:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="LicenseCustomerPhoneTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="E-Mail:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="2" Grid.Column="3" x:Name="LicenseCustomerEmailTextBox" Margin="0,0,0,6"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ansprechpartner:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="LicenseCustomerContactPersonTextBox" Margin="0,0,16,0"/>
                                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal">
                                    <Button Content="Speichern" Width="120" Margin="0,0,8,0" Click="SaveLicenseCustomerData_Click"/>
                                    <TextBlock x:Name="LicenseCustomerDataStatusText"
                                               VerticalAlignment="Center"
                                               Foreground="#2F6F4E"
                                               TextWrapping="Wrap"
                                               Text="Die Gerätenamen dienen nur der Dokumentation der Lizenzanfrage. Lizenzpflichtig ist ausschließlich die Anzahl aktivierter Geräteanbindungen."/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Lizenzanfrage exportieren" Width="190" Margin="0,0,8,0" Click="ExportLicenseRequest_Click"/>
                            <Button Content="Lizenz importieren" Width="190" Margin="0,0,8,0" Click="ImportLicenseFile_Click"/>
                            <Button Content="Karenzzeiten aktualisieren" Width="210" Click="UpdateGracePeriods_Click"/>
                        </StackPanel>

                        <GroupBox Header="Lizenzierte Geräte / Anbindungen" Grid.Row="4" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="340"/>
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                                    <TextBlock Text="Lizenzpflichtige Anbindungen gesamt:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceTotalCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Aktive lizenzpflichtige Anbindungen:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceActiveCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Lizenzierte Geräteanzahl:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceLicensedCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Gedeckt:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceCoveredCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="Nicht gedeckt:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceUncoveredCountText" MinWidth="36" Margin="0,0,18,6"/>
                                    <TextBlock Text="In Karenzzeit:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock x:Name="LicensedDeviceGraceCountText" MinWidth="36" Margin="0,0,0,6"/>
                                </WrapPanel>

                                <TextBlock Grid.Row="1"
                                           x:Name="LicensedDeviceStatusText"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>

                                <DataGrid Grid.Row="2"
                                          x:Name="LicensedDeviceStatesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          MinHeight="250">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" MinWidth="320" Width="*"/>
                                        <DataGridTextColumn Header="Aktiv" Binding="{Binding AktivText}" MinWidth="70" Width="70"/>
                                        <DataGridTextColumn Header="Lizenzpflichtig" Binding="{Binding LizenzpflichtigText}" MinWidth="110" Width="110"/>
                                        <DataGridTextColumn Header="Gedeckt" Binding="{Binding GedecktText}" MinWidth="90" Width="90"/>
                                        <DataGridTextColumn Header="Karenz" Binding="{Binding KarenzText}" MinWidth="90" Width="90"/>
                                        <DataGridTextColumn Header="Karenz bis" Binding="{Binding KarenzBisText}" MinWidth="140" Width="140"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" MinWidth="420" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Lizenzmeldungen" Grid.Row="5">
                            <TextBox x:Name="LicenseMessagesTextBox"
                                     Margin="8"
                                     MinHeight="280"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
            <StackPanel x:Name="TabUtilityButtonsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,4,12,0"
                        Panel.ZIndex="10">
                <Button x:Name="TabBaukastenUndoButton"
                        Content="↶"
                        Style="{StaticResource XdtBoxTabUtilityButtonStyle}"
                        ToolTip="Letzte Baukasten-Änderung rückgängig machen"
                        IsEnabled="False"
                        Click="XdtBaukastenUndo_Click"/>
                <Button x:Name="TabHelpButton"
                        Content="?"
                        Style="{StaticResource XdtBoxTabUtilityButtonStyle}"
                        ToolTip="Hilfe und Info"
                        Click="TabHelpButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Hilfe" Click="OpenHelpCenter_Click"/>
                            <MenuItem Header="Info" Click="OpenAboutDialog_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button x:Name="AppSettingsButton"
                        Content="⚙"
                        Style="{StaticResource XdtBoxTabUtilityButtonStyle}"
                        ToolTip="App-Einstellungen"
                        Click="OpenAppSettings_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
