                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              Height="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ShowsPreview="True"/>
