                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="Bitte zuerst AIS-Datei laden."/>
                                </GroupBox>

                                <Grid Grid.Row="2" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <GroupBox Header="Schritt 1 - AIS-Datei laden" Grid.Column="0">
                                        <Grid Margin="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Button Grid.Row="0"
                                                    Content="AIS-GDT/XDT-Datei auswählen"
                                                    HorizontalAlignment="Left"
                                                    Width="220"
                                                    Margin="0,0,0,8"
                                                    Click="SelectAisFile_Click"/>
                                            <TextBox Grid.Row="1"
                                                     x:Name="BuilderAisFilePathTextBox"
                                                     IsReadOnly="True"
                                                     Margin="0,0,0,8"
                                                     ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                            <TextBox Grid.Row="2"
                                                     x:Name="BuilderPatientSummaryTextBox"
                                                     IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     MinHeight="96"
                                                     Text="Noch keine AIS-Testdaten geladen."/>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Schritt 2 - Gerätedatei laden" Grid.Column="2">
                                        <Grid Margin="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Button Grid.Row="0"
                                                    Content="Gerätedatei auswählen"
                                                    HorizontalAlignment="Left"
                                                    Width="220"
                                                    Margin="0,0,0,8"
                                                    Click="SelectDeviceFile_Click"/>
                                            <TextBox Grid.Row="1"
                                                     x:Name="BuilderDeviceFilePathTextBox"
                                                     IsReadOnly="True"
                                                     Margin="0,0,0,8"
                                                     ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                            <TextBox Grid.Row="2"
                                                     x:Name="BuilderDeviceSummaryTextBox"
                                                     IsReadOnly="True"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     MinHeight="96"
                                                     Text="Noch keine Gerätedatei geladen."/>
                                        </Grid>
                                    </GroupBox>
                                </Grid>

                                <GroupBox Header="Schritt 3 - XDT-Anhang vorbereiten optional" Grid.Row="3" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="150"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Text="Optionaler Test für PDF/JPG/DCM/TXT-Anhänge und externe AIS-Linkfelder 6302-6305. Der Importordner wird nur gelesen; bei genau einer unterstützten stabilen Datei werden die Linkfelder transient für Vorschau und Testexport vorbereitet."
                                                   Foreground="DimGray"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Schnittstellenprofil:" FontWeight="Bold" Margin="0,3,8,8"/>
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  x:Name="BuilderAttachmentDiagnosticInterfaceProfileComboBox"
                                                  DisplayMemberPath="Metadata.Name"
                                                  MinWidth="320"
                                                  HorizontalAlignment="Stretch"
                                                  Margin="0,0,0,8"
                                                  SelectionChanged="AttachmentDiagnosticInterfaceProfileComboBox_SelectionChanged"
                                                  ToolTip="Aktives Schnittstellenprofil mit XDT-Anhang-Konfiguration für diesen manuellen Testpfad."/>

                                        <Button Grid.Row="2"
                                                Grid.Column="0"
                                                x:Name="BuilderReadXdtAttachmentButton"
                                                Content="XDT-Anhang einlesen"
                                                Margin="0,0,8,8"
                                                Click="ReadBuilderXdtAttachment_Click"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="Das Exportprofil steuert die XDT-Ergebnisfelder. Das Schnittstellenprofil verbindet AIS-Profil, Geräteprofil, Exportprofil, Ordner und XDT-Anhang-Einstellungen. XDT-Anhang-Linkfelder 6302-6305 werden im Baukasten nur transient zur Vorschau/Testausgabe ergänzt und verändern kein Exportprofil."
                                                   Foreground="DarkOrange"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,8"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Konfiguration:" FontWeight="Bold" Margin="0,3,8,8"/>
                                        <TextBox Grid.Row="3"
                                                 Grid.Column="1"
                                                 x:Name="BuilderAttachmentProfileDetailsTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 MinHeight="116"
                                                 Margin="0,0,0,8"
                                                 Text="Bitte erst Schnittstellenprofil anlegen."/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ausgewählter Anhang:" FontWeight="Bold" Margin="0,3,8,8"/>
                                        <TextBox Grid.Row="4"
                                                 Grid.Column="1"
                                                 x:Name="BuilderAttachmentDiagnosticFilePathTextBox"
                                                 IsReadOnly="True"
                                                 Margin="0,0,0,8"
                                                 ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                                        <DataGrid Grid.Row="5"
                                                  Grid.Column="0"
                                                  Grid.ColumnSpan="2"
                                                  x:Name="BuilderAttachmentDiagnosticCandidatesGrid"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto"
                                                  MinHeight="160"
                                                  Margin="0,0,0,8"
                                                  SelectionChanged="AttachmentDiagnosticCandidatesGrid_SelectionChanged">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Dateiname" Binding="{Binding FileName}" MinWidth="180" Width="180"/>
                                                <DataGridTextColumn Header="Endung" Binding="{Binding Extension}" MinWidth="80" Width="80"/>
                                                <DataGridTextColumn Header="Größe" Binding="{Binding SizeBytes}" MinWidth="90" Width="90"/>
                                                <DataGridTextColumn Header="Änderungsdatum" Binding="{Binding LastWriteTimeUtc, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}" MinWidth="150" Width="150"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" MinWidth="180" Width="180"/>
                                                 <DataGridTextColumn Header="Vollständiger Pfad" Binding="{Binding FullPath}" MinWidth="320" Width="*"/>
                                             </DataGrid.Columns>
                                         </DataGrid>

                                        <TextBlock Grid.Row="6"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   Text="Ergebnis:"
                                                   FontWeight="Bold"
                                                   Margin="0"/>

                                        <TextBox Grid.Row="7"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="2"
                                                 x:Name="BuilderAttachmentDiagnosticResultTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  TextWrapping="NoWrap"
                                                  MinHeight="96"
                                                  Margin="0"
                                                  Text="Noch kein XDT-Anhang vorbereitet."/>
                                    </Grid>
                                </GroupBox>

                                <Expander x:Name="BuilderMeasurementsExpander"
                                          Header="Schritt 4 - Messwerte prüfen"
                                          Grid.Row="4"
                                          IsExpanded="True"
                                          Margin="0,0,0,8">
                                    <DataGrid x:Name="BuilderMeasurementsGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              MinHeight="190"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="SourcePath" Binding="{Binding SourcePath}" Width="*"/>
                                            <DataGridTextColumn Header="Eye" Binding="{Binding Eye}" Width="80"/>
                                            <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120"/>
                                            <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="140"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="100"/>
                                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Expander>

                                <GroupBox Header="Schritt 5 - Gesamtexport-Vorschau XDT" Grid.Row="5" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                            <Button DockPanel.Dock="Right"
                                                    Content="Exportvorschau aktualisieren"
                                                    Width="220"
                                                    Margin="8,0,0,0"
                                                    Click="Process_Click"/>
                                            <TextBlock Text="Bitte zuerst AIS-Datei und Gerätedatei laden."
                                                       Foreground="DimGray"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBox x:Name="FullExportPreviewTextBox"
                                                 Grid.Row="1"
                                                 MinHeight="280"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 FontFamily="Consolas"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Schritt 6 - Testexport erstellen" Grid.Row="6">
                                    <DockPanel Margin="8">
                                        <Button DockPanel.Dock="Right"
                                                Content="Ausführen"
                                                Width="220"
                                                Margin="8,0,0,0"
                                                Click="RunBuilderTestExport_Click"/>
                                        <TextBlock Text="Öffnet eine Ordnerauswahl und schreibt eine Test-XDT-Datei mit den aktuell geladenen Beispielwerten. Ein eingelesener XDT-Anhang wird umbenannt und in denselben Testexport-Zielordner übernommen. Nicht für automatische Verarbeitung."
                                                   Foreground="DimGray"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </GroupBox>
                            </Grid>
                        </Expander>

                        <GridSplitter Grid.Row="10"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ShowsPreview="True"/>

                        <Expander Header="Verfügbare Platzhalter"
                                  IsExpanded="True"
                                  Grid.Row="11"
                                  Margin="0,0,0,8"
                                  ToolTip="Diese Werte können in OutputTemplates verwendet werden. Platzhalter müssen mit geschweiften Klammern geschrieben werden.">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8">
                                    Platzhalter müssen mit geschweiften Klammern geschrieben werden, z. B. {Device.R/AR/ARMedian/Sphere:Diopter}. Runde Klammern wie (Device.Date) werden nicht ersetzt.
                                    Über die Checkbox "Verwenden" kann ein Platzhalter in den aktuellen Entwurf eingefügt oder daraus entfernt werden. Der Ergebnistext bleibt weiterhin frei editierbar.
                                </TextBlock>
                                <TextBlock Grid.Row="1" Text="AIS-Platzhalter" FontWeight="Bold" Margin="0,0,0,4"/>
                                <DataGrid Grid.Row="2"
                                          x:Name="AisPlaceholdersGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasValue}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Platzhalter" Binding="{Binding Placeholder}" Width="230" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Name Messwert" Binding="{Binding DisplayName}" Width="180" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Ausgelesener Wert" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                                        <DataGridTemplateColumn Header="Ausgabeart" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding OutputModes}"
                                                              SelectedItem="{Binding OutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectionChanged="PlaceholderOutputModeComboBox_SelectionChanged"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Verwenden" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsUsed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              Checked="PlaceholderUseCheckBox_Changed"
                                                              Unchecked="PlaceholderUseCheckBox_Changed"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <GridSplitter Grid.Row="3"
                                              Height="6"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ResizeDirection="Rows"
                                              ShowsPreview="True"/>

                                <TextBlock Grid.Row="4" x:Name="DevicePlaceholdersStatusText" Text="Device-Platzhalter" FontWeight="Bold" Margin="0,8,0,4"/>
                                <DataGrid Grid.Row="5"
                                          x:Name="DevicePlaceholdersGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasValue}" Value="True">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Platzhalter" Binding="{Binding Placeholder}" Width="260" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Name Messwert" Binding="{Binding DisplayName}" Width="230" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Ausgelesener Wert" Binding="{Binding Value}" Width="*" IsReadOnly="True"/>
                                        <DataGridTemplateColumn Header="Ausgabeart" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding OutputModes}"
                                                              SelectedItem="{Binding OutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              SelectionChanged="PlaceholderOutputModeComboBox_SelectionChanged"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Verwenden" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsUsed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center"
                                                              Checked="PlaceholderUseCheckBox_Changed"
                                                              Unchecked="PlaceholderUseCheckBox_Changed"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Expander>

                        <Expander Header="Profil- und Template-Meldungen" IsExpanded="True" Grid.Row="12">
                            <TextBox x:Name="ProfileMessagesTextBox"
                                     Margin="8"
                                     MinHeight="160"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Expander>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="XDT-Baukasten">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid x:Name="XdtBaukastenRoot" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="Baukasten-Aktionen">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <UniformGrid Grid.Column="0" Columns="1" Rows="4">
                                    <Button x:Name="XdtBaukastenLoadTemplatePackageButton" Content="Templatepaket laden" Margin="0,0,0,8" Click="XdtBaukastenLoadTemplatePackage_Click" />
                                    <Button x:Name="XdtBaukastenImportTemplatePackageButton" Content="Template Paket importieren" Margin="0,0,0,8" Click="XdtBaukastenImportTemplatePackage_Click" />
                                    <Button x:Name="XdtBaukastenNewAisButton" Content="Neues AIS anlegen" Margin="0,0,0,8" Click="XdtBaukastenNewAis_Click" />
                                    <Button x:Name="XdtBaukastenLoadDeviceButton" Content="Gerät laden" Click="XdtBaukastenLoadDevice_Click" />
                                </UniformGrid>

                                <UniformGrid Grid.Column="2" Columns="1" Rows="4">
                                    <Button x:Name="XdtBaukastenSaveTemplateButton" Content="Konfiguration als Template speichern" Margin="0,0,0,8" Click="XdtBaukastenSaveTemplate_Click" />
                                    <Button x:Name="XdtBaukastenExportTemplatePackageButton" Content="Template Paket exportieren" Margin="0,0,0,8" Click="XdtBaukastenExportTemplatePackage_Click" />
                                    <Button x:Name="XdtBaukastenChooseAisButton" Content="AIS wählen" Margin="0,0,0,8" Click="XdtBaukastenChooseAis_Click" />
                                    <Button x:Name="XdtBaukastenNewDeviceButton" Content="Neues Gerät anlegen" Click="XdtBaukastenNewDevice_Click" />
                                </UniformGrid>
                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="3"
                                        Margin="0,10,0,0"
                                        Padding="10,8"
                                        Background="{StaticResource XdtBoxPanelBackgroundBrush}"
                                        BorderBrush="{StaticResource XdtBoxBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock x:Name="XdtBaukastenTopStatusText"
                                                   Foreground="{StaticResource XdtBoxMutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="Baukasten bereit. Bitte Profile und Testdaten laden." />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource XdtBoxMutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="Baukastenmodus: Modellabweichungen werden als Warnung angezeigt, blockieren die Vorschau aber nicht. Die produktive Verarbeitung prüft strenger." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="1" Header="Geräteidentität">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border BorderBrush="{StaticResource XdtBoxBorderBrush}" BorderThickness="1" CornerRadius="8" Background="White" Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="150" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Image x:Name="XdtBaukastenDeviceImage"
                                               Source="{Binding Text, ElementName=XdtBaukastenDeviceImagePathTextBox, Converter={StaticResource DeviceImageSourceConverter}}"
                                               Stretch="Uniform"
                                               MouseLeftButtonUp="XdtBaukastenDeviceImage_MouseLeftButtonUp" />
                                        <TextBlock x:Name="XdtBaukastenDeviceImagePlaceholder"
                                                   Text="Geräte Bild&#x0a;&#x0a;Mit Klick austauschbar"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource XdtBoxMutedTextBrush}" />
                                        <TextBox x:Name="XdtBaukastenDeviceImagePathTextBox" Visibility="Collapsed" />
                                        <TextBlock Grid.Row="1"
                                                   Text="Bild per Klick austauschbar"
                                                   Margin="0,8,0,0"
                                                   TextAlignment="Center"
                                                   Foreground="{StaticResource XdtBoxMutedTextBrush}" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS-Profil:" FontWeight="SemiBold" Margin="0,0,8,8" />
                                    <ComboBox x:Name="XdtBaukastenAisProfileComboBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" DisplayMemberPath="Metadata.Name" SelectionChanged="XdtBaukastenAisProfileComboBox_SelectionChanged" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Geräteprofil:" FontWeight="SemiBold" Margin="0,0,8,8" />
                                    <ComboBox x:Name="XdtBaukastenDeviceProfileComboBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" DisplayMemberPath="Metadata.Name" SelectionChanged="XdtBaukastenDeviceProfileComboBox_SelectionChanged" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Gerätename:" FontWeight="SemiBold" Margin="0,0,8,6" />
                                    <TextBlock x:Name="XdtBaukastenDeviceNameText" Grid.Row="2" Grid.Column="1" Margin="0,0,16,6" Text="Kein Gerät geladen" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Hersteller:" FontWeight="SemiBold" Margin="0,0,8,6" />
                                    <TextBlock x:Name="XdtBaukastenManufacturerText" Grid.Row="2" Grid.Column="3" Margin="0,0,0,6" Text="-" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Verbindung:" FontWeight="SemiBold" Margin="0,0,8,6" />
                                    <TextBlock x:Name="XdtBaukastenConnectionKindText" Grid.Row="3" Grid.Column="1" Margin="0,0,16,6" Text="-" />
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Gerätetyp:" FontWeight="SemiBold" Margin="0,0,8,6" />
                                    <TextBlock x:Name="XdtBaukastenDeviceTypeText" Grid.Row="3" Grid.Column="3" Margin="0,0,0,6" Text="-" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Bidirektional:" FontWeight="SemiBold" Margin="0,0,8,6" />
                                    <TextBlock x:Name="XdtBaukastenBidirectionalText" Grid.Row="4" Grid.Column="1" Margin="0,0,16,6" Text="-" />
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Geräteparser:" FontWeight="SemiBold" Margin="0,0,8,6" />
                                    <TextBlock x:Name="XdtBaukastenParserText" Grid.Row="4" Grid.Column="3" Margin="0,0,0,6" Text="-" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Profilname:" FontWeight="SemiBold" Margin="0,0,8,6" />
                                    <TextBlock x:Name="XdtBaukastenProfileNameText" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Text="-" />
                                </Grid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Header="Testdaten und Rohdaten">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <Button x:Name="XdtBaukastenLoadAisOrSerialButton" Content="AIS Datei laden" MinWidth="180" Margin="0,0,12,0" Click="XdtBaukastenLoadAisOrSerial_Click" />
                                    <Button x:Name="XdtBaukastenLoadAttachmentButton" Content="Dateianhang laden" MinWidth="180" Margin="0,0,12,0" Click="XdtBaukastenLoadAttachment_Click" />
                                    <Button x:Name="XdtBaukastenLoadDeviceFileButton" Content="Gerätedatei laden" MinWidth="180" Click="XdtBaukastenLoadDeviceFile_Click" />
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <GroupBox x:Name="XdtBaukastenPrimaryRawGroupBox" Header="Anzeige Rohdaten von AIS Datei">
                                        <TextBox x:Name="XdtBaukastenAisRawTextBox"
                                                 MinHeight="220"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"
                                                 IsReadOnly="True" />
                                    </GroupBox>
                                    <GroupBox Grid.Column="2" Header="Anzeige Rohdaten vom Gerät">
                                        <TextBox x:Name="XdtBaukastenDeviceRawTextBox"
                                                 MinHeight="220"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 TextWrapping="NoWrap"
                                                 IsReadOnly="True" />
                                    </GroupBox>
                                </Grid>

                                <TextBlock x:Name="XdtBaukastenAttachmentStatusText" Grid.Row="2" Margin="0,8,0,0" Foreground="{StaticResource XdtBoxMutedTextBrush}" Text="Kein Dateianhang geladen." />
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="3" Header="Mapping, Verarbeitung und Ergebnis">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="XdtBaukastenChooseExportProfileButton" Content="Mapping / Exportprofil" MinWidth="180" Margin="0,0,12,0" Click="XdtBaukastenChooseExportProfile_Click" />
                                    <ComboBox x:Name="XdtBaukastenExportProfileComboBox" MinWidth="380" DisplayMemberPath="Metadata.Name" SelectionChanged="XdtBaukastenExportProfileComboBox_SelectionChanged" />
                                    <Button x:Name="XdtBaukastenStartProcessingButton" Content="Verarbeitung starten" MinWidth="180" Margin="12,0,0,0" Click="XdtBaukastenStartProcessing_Click" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Ansicht:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                                    <ComboBox x:Name="XdtBaukastenResultViewComboBox" MinWidth="180" SelectedIndex="0" SelectionChanged="XdtBaukastenResultViewComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Roh-XDT" Tag="RawXdt" />
                                        <ComboBoxItem Content="Ansicht im AIS" Tag="AisView" />
                                        <ComboBoxItem Content="Geräteausgabe" Tag="DeviceOutput" />
                                        <ComboBoxItem Content="Diagnose" Tag="Diagnostics" />
                                    </ComboBox>
                                </StackPanel>

                                <TextBlock x:Name="XdtBaukastenStatusText" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,8" Foreground="{StaticResource XdtBoxMutedTextBrush}" Text="Baukasten bereit. Bitte Profile und Testdaten laden." />

                                <GroupBox x:Name="XdtBaukastenResultGroupBox" Grid.Row="2" Grid.ColumnSpan="2" Header="Roh-XDT-Ausgabe an das AIS">
                                    <Grid>
                                        <DataGrid x:Name="XdtBaukastenResultLinesGrid"
                                                  MinHeight="260"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  FontFamily="Consolas"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  SelectionMode="Extended"
                                                  SelectionUnit="FullRow">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="{x:Type DataGridRow}">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                            <Setter Property="Background" Value="#FFF4C2" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                            <Setter Property="Foreground" Value="#8A4B00" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="#" Binding="{Binding LineNumber}" Width="54" />
                                                <DataGridTextColumn Header="Ausgabe" Binding="{Binding Text}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <TextBox x:Name="XdtBaukastenResultTextBox"
                                                 Visibility="Collapsed"
                                                 IsReadOnly="True" />
                                    </Grid>
                                </GroupBox>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="4" Header="Konfiguration Exportregeln">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border x:Name="XdtBaukastenRuleDirectionPanel"
                                        Grid.Row="0"
                                        Margin="0,0,0,8"
                                        Padding="8"
                                        Background="{StaticResource XdtBoxPanelBackgroundBrush}"
                                        BorderBrush="{StaticResource XdtBoxBorderBrush}"
                                        BorderThickness="1">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="Richtung:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <RadioButton x:Name="XdtBaukastenRuleDirectionAisRadioButton"
                                                         Content="Export an AIS"
                                                         GroupName="XdtBaukastenRuleDirection"
                                                         IsChecked="True"
                                                         Margin="0,0,16,0"
                                                         VerticalAlignment="Center"
                                                         Checked="XdtBaukastenRuleDirection_Checked" />
                                            <RadioButton x:Name="XdtBaukastenRuleDirectionDeviceOutputRadioButton"
                                                         Content="Export an Gerät"
                                                         GroupName="XdtBaukastenRuleDirection"
                                                         Margin="0,0,16,0"
                                                         VerticalAlignment="Center"
                                                         Checked="XdtBaukastenRuleDirection_Checked" />
                                        </StackPanel>
                                        <TextBlock x:Name="XdtBaukastenRuleDirectionHintText"
                                                   Text="Export an AIS ist aktiv."
                                                   Foreground="{StaticResource XdtBoxMutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>

                                <DataGrid x:Name="XdtBaukastenExportRulesGrid"
                                          Grid.Row="1"
                                          MinHeight="220"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionChanged="XdtBaukastenExportRulesGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn x:Name="XdtBaukastenRuleNumberColumn" Header="#" Binding="{Binding RowNumber}" Width="46" />
                                        <DataGridTextColumn Header="Aktiv" Binding="{Binding Rule.IsEnabled}" Width="70" />
                                        <DataGridTextColumn x:Name="XdtBaukastenRuleTargetColumn" Header="Feld" Binding="{Binding Rule.TargetFieldCode}" Width="130" />
                                        <DataGridTextColumn x:Name="XdtBaukastenRuleTargetNameColumn" Header="Name" Binding="{Binding Rule.TargetName}" Width="180" />
                                        <DataGridTextColumn Header="SourcePath" Binding="{Binding Rule.SourcePath}" Width="220" />
                                        <DataGridTextColumn Header="Template" Binding="{Binding Rule.OutputTemplate}" Width="*" />
                                        <DataGridTemplateColumn Header="" Width="54">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="🗑"
                                                            Tag="{Binding Rule}"
                                                            ToolTip="Exportregel aus der Baukasten-Arbeitskopie löschen"
                                                            Click="XdtBaukastenDeleteExportRule_Click" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Button x:Name="XdtBaukastenAddExportRuleButton"
                                        Grid.Row="2"
                                        Content="+"
                                        Width="44"
                                        HorizontalAlignment="Right"
                                        Margin="0,8,4,0"
                                        ToolTip="Neue Exportregel in der Baukasten-Arbeitskopie hinzufügen"
                                        Click="XdtBaukastenAddExportRule_Click" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="5" Header="Exportregel Entwurf">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="XdtBaukastenDraftTargetLabel" Grid.Row="0" Grid.Column="0" Text="Ziel-Feld:" FontWeight="SemiBold" Margin="0,0,8,8" />
                                <TextBox x:Name="XdtBaukastenDraftTargetFieldCodeTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,16,8" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Zielname:" FontWeight="SemiBold" Margin="0,0,8,8" />
                                <TextBox x:Name="XdtBaukastenDraftTargetNameTextBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,8" />

                                <TextBlock x:Name="XdtBaukastenDraftSourceLabel" Grid.Row="1" Grid.Column="0" Text="SourcePath:" FontWeight="SemiBold" Margin="0,0,8,8" />
                                <TextBox x:Name="XdtBaukastenDraftSourcePathTextBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Regeltext:" FontWeight="SemiBold" Margin="0,0,8,8" />
                                <TextBox x:Name="XdtBaukastenDraftOutputTemplateTextBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         MinHeight="88"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         TextWrapping="Wrap" />

                                <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="XdtBaukastenApplyDraftRuleButton" Content="Entwurf in Arbeitskopie übernehmen" MinWidth="240" Margin="0,0,12,0" Click="XdtBaukastenApplyDraftRule_Click" />
                                    <TextBlock x:Name="XdtBaukastenDraftStatusText" VerticalAlignment="Center" Foreground="{StaticResource XdtBoxMutedTextBrush}" Text="Keine Exportregel ausgewählt." />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="6" Header="Verfügbare Platzhalter">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="AIS-/Patienten-Platzhalter">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                        <ItemsControl x:Name="XdtBaukastenAisPlaceholderItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button ToolTip="{Binding Description}" Tag="{Binding Token}" Margin="0,0,0,6" HorizontalContentAlignment="Stretch" Click="XdtBaukastenPlaceholder_Click">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ExampleValue}"
                                                                       Margin="12,0,0,0"
                                                                       HorizontalAlignment="Right"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{StaticResource XdtBoxMutedTextBrush}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </GroupBox>

                                <GroupBox Grid.Column="2" Header="Geräte-/Messwert-Platzhalter">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                        <ItemsControl x:Name="XdtBaukastenDevicePlaceholderItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button ToolTip="{Binding Description}" Tag="{Binding Token}" Margin="0,0,0,6" HorizontalContentAlignment="Stretch" Click="XdtBaukastenPlaceholder_Click">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ExampleValue}"
                                                                       Margin="12,0,0,0"
                                                                       HorizontalAlignment="Right"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{StaticResource XdtBoxMutedTextBrush}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </GroupBox>

                                <GroupBox Grid.Column="4" Header="Ausgabe-an-Gerät-Platzhalter">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="260">
                                        <ItemsControl x:Name="XdtBaukastenDeviceOutputPlaceholderItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button ToolTip="{Binding Description}" Tag="{Binding Token}" Margin="0,0,0,6" HorizontalContentAlignment="Stretch" Click="XdtBaukastenPlaceholder_Click">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ExampleValue}"
                                                                       Margin="12,0,0,0"
                                                                       HorizontalAlignment="Right"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{StaticResource XdtBoxMutedTextBrush}" />
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </GroupBox>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Schnittstellenprofile">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Hier wird später gesteuert, welche Schnittstelle automatisch über Ordner verarbeitet wird. In diesem Schritt werden nur Einstellungen gespeichert. Es findet noch keine automatische Ordnerüberwachung statt."
                                   Foreground="DimGray"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <GroupBox Header="Schnittstellenprofil / Automatische Verarbeitung" Grid.Row="1">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Schnittstellenprofil:" FontWeight="Bold" Margin="0,0,8,8"/>
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          x:Name="InterfaceProfileComboBox"
                                          DisplayMemberPath="Metadata.Name"
                                          MinWidth="260"
                                          MaxWidth="560"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,8"
                                          ToolTip="{Binding SelectedItem.Metadata.Name, RelativeSource={RelativeSource Self}}"
                                          SelectionChanged="InterfaceProfileComboBox_SelectionChanged"/>
                                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="0,0,0,8">
                                    <Button Content="Neues Schnittstellenprofil anlegen"
                                            Width="260"
                                            Margin="0,0,8,8"
                                            Click="CreateNewInterfaceProfile_Click"/>
                                    <Button Content="Schnittstellenprofil für ausgewähltes Exportprofil erstellen"
                                            Width="360"
                                            Margin="0,0,8,8"
                                            Click="CreateInterfaceProfileForSelectedExport_Click"/>
                                    <Button Content="Schnittstellenprofil entfernen"
                                            Width="210"
                                            Margin="0,0,8,8"
                                            Click="RemoveInterfaceProfile_Click"/>
                                    <Button x:Name="RenameInterfaceProfileButton"
                                            Content="Schnittstellenprofil umbenennen"
                                            Width="250"
                                            Margin="0,0,8,8"
                                            Click="RenameSelectedInterfaceProfile_Click"
                                            ToolTip="Ändert nur den sichtbaren Namen eines UserDefined-Schnittstellenprofils."
                                            ToolTipService.ShowOnDisabled="True"/>
                                    <Button x:Name="SaveInterfaceProfileButton"
                                            Content="Speichern"
                                            Width="220"
                                            Margin="0,0,0,8"
                                            Click="SaveInterfaceProfile_Click"/>
                                    <TextBlock x:Name="InterfaceProfileSaveFeedbackText"
                                               MinWidth="95"
                                               Margin="8,2,0,8"
                                               VerticalAlignment="Center"
                                               Foreground="#1D7D46"
                                               FontWeight="SemiBold"
                                               Text=""/>
                                </WrapPanel>

                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS-Profil:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InterfaceAisProfileText" Margin="0,0,0,6" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Geräteprofil:" FontWeight="Bold" Margin="0,0,8,6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InterfaceDeviceProfileText" Margin="0,0,0,6" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Exportprofil:" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InterfaceExportProfileText" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                </Grid>

                                <WrapPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <CheckBox x:Name="InterfaceIsActiveCheckBox" Content="Für automatische Verarbeitung aktiv" Margin="0,0,24,8"/>
                                    <CheckBox x:Name="InterfaceIsLicenseRequiredCheckBox" Content="Lizenzpflichtig" Margin="0,0,24,8"/>
                                </WrapPanel>

                                <Expander Header="Ordner" IsExpanded="True" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                    <Grid Margin="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="96"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AIS-Patienten Datei an XDTBox:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="InterfaceAisImportFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="AisImport" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="InterfaceDeviceImportFolderLabel" Text="Gerätedatei an XDTBox:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="InterfaceDeviceImportFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="1" Grid.Column="2" x:Name="InterfaceDeviceImportFolderButton" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="DeviceImport" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ergebnisdatei an AIS:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="InterfaceExportFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="Export" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Archivordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="InterfaceArchiveFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="3" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="Archive" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Fehlerordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="InterfaceErrorFolderTextBox" Margin="0,0,8,8" HorizontalScrollBarVisibility="Auto" ToolTip="UNC-Pfade wie \\SERVER\Freigabe\Ordner sind erlaubt."/>
                                        <Button Grid.Row="4" Grid.Column="2" Content="Auswählen" Width="90" Margin="0,0,0,8" Tag="Error" Click="SelectInterfaceFolder_Click"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ordnerabfrage-Intervall:" FontWeight="Bold" Margin="0,0,8,8"/>
                                        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBox x:Name="InterfaceAutoImportScanIntervalSecondsTextBox"
                                                     Width="120"
                                                     Text="5"
                                                     ToolTip="Intervall der manuell gestarteten periodischen Ordnerabfrage in Sekunden. Minimum: 1 Sekunde."/>
                                            <TextBlock Text=" Sekunden" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="6" Grid.Column="0" x:Name="InterfaceDeviceFileWaitTimeoutLabel" Text="Wartezeit auf Gerätedatei:" FontWeight="Bold" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" x:Name="InterfaceDeviceFileWaitTimeoutPanel" Orientation="Horizontal">
                                            <TextBox x:Name="InterfaceDeviceFileWaitTimeoutMinutesTextBox"
                                                     Width="120"
                                                     Text="10"
                                                     ToolTip="Maximale Wartezeit, nachdem eine AIS-Datei erkannt wurde, bis eine passende Gerätedatei erwartet wird. 0 bedeutet: nicht warten."/>
                                            <TextBlock Text=" Minuten" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>

                                        <WrapPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" VerticalAlignment="Center">
                                            <Button x:Name="InterfaceFolderDefaultButton"
                                                    Content="Ordner Default"
                                                    Width="120"
                                                    Margin="0,0,8,6"
                                                    Click="ApplyInterfaceFolderDefaults_Click"
                                                    ToolTip="Trägt Standardpfade unter C:\XDTBox für das aktuelle Geräteprofil ein. Es werden noch keine Ordner erstellt."/>
                                            <Button x:Name="InterfaceCreateFoldersButton"
                                                    Content="Ordner anlegen"
