<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="XdtBoxPrimaryColor">#0B4D93</Color>
    <Color x:Key="XdtBoxPrimaryDarkColor">#073763</Color>
    <Color x:Key="XdtBoxAccentColor">#18BFC3</Color>
    <Color x:Key="XdtBoxDarkTextColor">#24313A</Color>
    <Color x:Key="XdtBoxMutedTextColor">#667481</Color>
    <Color x:Key="XdtBoxWindowBackgroundColor">#F4F8FB</Color>
    <Color x:Key="XdtBoxPanelBackgroundColor">#FFFFFF</Color>
    <Color x:Key="XdtBoxBorderColor">#D7E3EA</Color>
    <Color x:Key="XdtBoxButtonHoverColor">#E8F6F8</Color>
    <Color x:Key="XdtBoxButtonPressedColor">#D3EEF1</Color>

    <SolidColorBrush x:Key="XdtBoxPrimaryBrush" Color="{StaticResource XdtBoxPrimaryColor}" />
    <SolidColorBrush x:Key="XdtBoxPrimaryDarkBrush" Color="{StaticResource XdtBoxPrimaryDarkColor}" />
    <SolidColorBrush x:Key="XdtBoxAccentBrush" Color="{StaticResource XdtBoxAccentColor}" />
    <SolidColorBrush x:Key="XdtBoxDarkTextBrush" Color="{StaticResource XdtBoxDarkTextColor}" />
    <SolidColorBrush x:Key="XdtBoxMutedTextBrush" Color="{StaticResource XdtBoxMutedTextColor}" />
    <SolidColorBrush x:Key="XdtBoxWindowBackgroundBrush" Color="{StaticResource XdtBoxWindowBackgroundColor}" />
    <SolidColorBrush x:Key="XdtBoxPanelBackgroundBrush" Color="{StaticResource XdtBoxPanelBackgroundColor}" />
    <SolidColorBrush x:Key="XdtBoxBorderBrush" Color="{StaticResource XdtBoxBorderColor}" />
    <SolidColorBrush x:Key="XdtBoxButtonHoverBrush" Color="{StaticResource XdtBoxButtonHoverColor}" />
    <SolidColorBrush x:Key="XdtBoxButtonPressedBrush" Color="{StaticResource XdtBoxButtonPressedColor}" />

    <LinearGradientBrush x:Key="XdtBoxHeaderBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#EAF7F8" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="XdtBoxRootGridStyle" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource XdtBoxWindowBackgroundBrush}" />
    </Style>

    <Style x:Key="XdtBoxBrandHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource XdtBoxHeaderBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="XdtBoxLogoImageStyle" TargetType="Image">
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Height" Value="58" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource XdtBoxWindowBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource XdtBoxDarkTextBrush}" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Margin" Value="0,0,2,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource XdtBoxPrimaryBrush}" />
                <Setter Property="Background" Value="{StaticResource XdtBoxPanelBackgroundBrush}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource XdtBoxPrimaryDarkBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource XdtBoxDarkTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="Background" Value="{StaticResource XdtBoxPanelBackgroundBrush}" />
    </Style>

    <Style TargetType="Expander">
        <Setter Property="Foreground" Value="{StaticResource XdtBoxDarkTextBrush}" />
        <Setter Property="Background" Value="{StaticResource XdtBoxPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="XdtBoxTabUtilityButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Background" Value="{StaticResource XdtBoxPanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource XdtBoxPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource XdtBoxPanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource XdtBoxDarkTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource XdtBoxDarkTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource XdtBoxDarkTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource XdtBoxDarkTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource XdtBoxBorderBrush}" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#F7FBFC" />
    </Style>
</ResourceDictionary>
