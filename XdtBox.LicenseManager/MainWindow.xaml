<Window x:Class="XdtBox.LicenseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XDTBox Hersteller-Lizenzverwaltung"
        Icon="Assets/App/XDTBox.ico"
        Height="820"
        Width="1220"
        MinHeight="720"
        MinWidth="1080"
        Background="{DynamicResource XdtBoxWindowBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/XdtBoxTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="10" Style="{StaticResource XdtBoxRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource XdtBoxBrandHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="Assets/Branding/XDTBox_Logo_Schriftzug.png"
                       Style="{StaticResource XdtBoxLogoImageStyle}"
                       MaxWidth="340"/>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="Interne Hersteller-Lizenzverwaltung"
                               Foreground="{StaticResource XdtBoxDarkTextBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="Lizenzanfragen einlesen, signieren und nachvollziehbar historisieren"
                               Foreground="{StaticResource XdtBoxMutedTextBrush}"
                               FontSize="12"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>
        <TabControl x:Name="LicenseManagerTabs" Grid.Row="1">
            <TabItem Header="Lizenz erstellen">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Lizenzanfrage" Grid.Row="0" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Row="0" Grid.Column="0" Content="Lizenzanfrage öffnen" Width="150" Click="OpenRequest_Click"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RequestFileTextBox" Margin="8,0,0,6" IsReadOnly="True"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="InstallationId:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="InstallationIdTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Request-Datum:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="RequestDateTextBlock" Margin="0,0,0,6"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="App-Version:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RequestAppVersionTextBlock" Margin="0,0,16,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Aktive Geräte:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="RequestedActiveConnectionsTextBlock"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Kundendaten" Grid.Row="1" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Praxis/Firma:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" x:Name="CustomerNameTextBox" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Straße:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="StreetTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="PLZ / Ort:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBox x:Name="PostalCodeTextBox" Width="90" Margin="0,0,8,0"/>
                                    <TextBox x:Name="CityTextBox" MinWidth="220"/>
                                </StackPanel>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Telefon:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="PhoneTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="E-Mail:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="2" Grid.Column="3" x:Name="EmailTextBox" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ansprechpartner:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" x:Name="ContactPersonTextBox"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Angeforderte Geräteanbindungen" Grid.Row="2" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="180"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Margin="0,0,0,6" Foreground="#666666"
                                           Text="Gerätenamen dienen nur der Dokumentation. Lizenzpflichtig ist ausschließlich die Anzahl aktivierter Geräteanbindungen."/>
                                <DataGrid Grid.Row="1"
                                          x:Name="RequestDevicesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50"/>
                                        <DataGridTextColumn Header="Schnittstellenprofil" Binding="{Binding DisplayName}" Width="2*"/>
                                        <DataGridTextColumn Header="Geräteprofil" Binding="{Binding DeviceDisplayName}" Width="2*"/>
                                        <DataGridTextColumn Header="Anbindung" Binding="{Binding ConnectionKind}" Width="120"/>
                                        <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsActive}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Lizenzparameter" Grid.Row="3" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Lizenznehmer:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="LicenseeTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Kundennummer:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="2" x:Name="CustomerNumberTextBox" Margin="0,0,0,6"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max. Geräteanbindungen:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="MaxActiveConnectionsTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Lizenztyp:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <ComboBox Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" x:Name="LicenseTypeComboBox" Margin="0,0,0,6">
                                    <ComboBoxItem Content="Production" IsSelected="True"/>
                                    <ComboBoxItem Content="Trial"/>
                                    <ComboBoxItem Content="Support"/>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Gültig ab:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <DatePicker Grid.Row="2" Grid.Column="1" x:Name="ValidFromDatePicker" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Gültig bis:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <DatePicker Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" x:Name="ValidUntilDatePicker" Margin="0,0,0,6"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Karenzzeit Tage:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="GraceDaysTextBox" Margin="0,0,16,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="KeyId:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2" x:Name="KeyIdTextBox" Margin="0,0,0,6"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Private-Key-Pfad:" FontWeight="Bold" Margin="0,0,8,6"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="PrivateKeyPathTextBox" Margin="0,0,8,6"/>
                                <Button Grid.Row="4" Grid.Column="4" Content="Auswählen" Click="BrowsePrivateKey_Click" Margin="0,0,0,6"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Ausgabedatei:" FontWeight="Bold" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" x:Name="OutputFileTextBox" Margin="0,0,8,0"/>
                                <Button Grid.Row="5" Grid.Column="4" Content="Vorschlag" Click="SuggestOutputFile_Click"/>
                            </Grid>
                        </GroupBox>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" x:Name="NotesTextBox" Height="70" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,8" ToolTip="Notiz"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <Button Content="Lizenz erzeugen" Width="150" Margin="0,0,8,0" Click="CreateLicense_Click"/>
                                <Button Content="Ausgabeordner öffnen" Width="160" Margin="0,0,8,0" Click="OpenOutputFolder_Click"/>
                                <Button Content="Eingaben zurücksetzen" Width="160" Margin="0,0,8,0" Click="ResetInputs_Click"/>
                                <TextBlock x:Name="CreateLicenseStatusText" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Ausgestellte Lizenzen">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Suche:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="HistorySearchTextBox" Width="320" Margin="0,0,8,0" TextChanged="HistorySearchTextBox_TextChanged"/>
                        <Button Content="Historie neu laden" Width="140" Margin="0,0,8,0" Click="ReloadHistory_Click"/>
                        <Button Content="Historie exportieren" Width="140" Click="ExportHistory_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid Grid.Column="0"
                                  x:Name="HistoryGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionChanged="HistoryGrid_SelectionChanged"
                                  Margin="0,0,8,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kunde" Binding="{Binding CustomerName}" Width="2*"/>
                                <DataGridTextColumn Header="Kundennummer" Binding="{Binding CustomerNumber}" Width="120"/>
                                <DataGridTextColumn Header="Ort" Binding="{Binding City}" Width="120"/>
                                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130"/>
                                <DataGridTextColumn Header="InstallationId" Binding="{Binding ShortInstallationId}" Width="140"/>
                                <DataGridTextColumn Header="Geräte" Binding="{Binding MaxActiveDeviceConnections}" Width="70"/>
                                <DataGridTextColumn Header="Gültig bis" Binding="{Binding ValidUntilDisplay}" Width="110"/>
                                <DataGridTextColumn Header="Typ" Binding="{Binding LicenseType}" Width="110"/>
                                <DataGridTextColumn Header="Ausgestellt" Binding="{Binding IssuedAtDisplay}" Width="120"/>
                                <DataGridTextColumn Header="LicenseId" Binding="{Binding LicenseId}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GroupBox Grid.Column="1" Header="Details">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" x:Name="HistoryDetailsTextBlock" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <DataGrid Grid.Row="1"
                                          x:Name="HistoryDevicesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          Height="180"
                                          Margin="0,0,0,8">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Anbindung" Binding="{Binding DisplayName}" Width="*"/>
                                        <DataGridTextColumn Header="Gerät" Binding="{Binding DeviceDisplayName}" Width="*"/>
                                        <DataGridTextColumn Header="Quelle" Binding="{Binding ConnectionKind}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <WrapPanel Grid.Row="2">
                                    <Button Content="Lizenzdatei öffnen" Width="140" Margin="0,0,8,8" Click="OpenSelectedLicenseFile_Click"/>
                                    <Button Content="Ordner öffnen" Width="120" Margin="0,0,8,8" Click="OpenSelectedLicenseFolder_Click"/>
                                    <Button Content="Neue Lizenz für diesen Kunden erstellen" Width="240" Margin="0,0,8,8" Click="CreateNewForSelectedCustomer_Click"/>
                                    <Button Content="Kundendaten übernehmen" Width="170" Margin="0,0,8,8" Click="UseSelectedCustomerData_Click"/>
                                </WrapPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <TextBlock Grid.Row="2" x:Name="HistoryStatusText" Margin="0,8,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="Einstellungen">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Standard-Ausgabeordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="SettingsOutputFolderTextBox" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Standard-Request-Ordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="SettingsRequestFolderTextBox" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Standard-Key-Ordner:" FontWeight="Bold" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="SettingsKeyFolderTextBox" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Private-Key-Pfad:" FontWeight="Bold" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="SettingsPrivateKeyPathTextBox" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="KeyId:" FontWeight="Bold" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="SettingsKeyIdTextBox" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Issuer / Karenzzeit:" FontWeight="Bold" Margin="0,0,8,8"/>
                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="SettingsIssuerTextBox" Width="260" Margin="0,0,8,0"/>
                        <TextBox x:Name="SettingsGraceDaysTextBox" Width="80"/>
                        <TextBlock Text=" Tage" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2">
                        <Border BorderBrush="#E0A126" BorderThickness="1" Background="#FFF4D6" Padding="8" Margin="0,0,0,8">
                            <TextBlock Text="Der private Schlüssel bleibt ausschließlich beim Hersteller. Die Datei darf nicht weitergegeben und nicht ins Repository übernommen werden." TextWrapping="Wrap"/>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Einstellungen speichern" Width="180" Margin="0,0,8,0" Click="SaveSettings_Click"/>
                            <Button Content="Arbeitsordner anlegen" Width="160" Margin="0,0,8,0" Click="CreateWorkingFolders_Click"/>
                            <TextBlock x:Name="SettingsStatusText" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
